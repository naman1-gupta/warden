!dist/action/licenses.txt
!dist/action/sourcemap-register.cjs
!dist/action/package.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
