/.dex/*
!/.dex/config.toml

# Dependencies
node_modules/

# Build output (but allow dist/action/ for GitHub Action bundle)
dist/*
!dist/action/

# GitHub Action bundle - only ncc output files (must be committed for action to work)
dist/action/*
!dist/action/index.js
!dist/action/index.js.map
!dist/action/*.index.js
!dist/action/*.index.js.map
!dist/action/licenses.txt
!dist/action/sourcemap-register.cjs
!dist/action/package.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
