---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import PackageManagerTabs from '../components/PackageManagerTabs.astro';
import { Code } from 'astro:components';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const skillExample = `---
name: security-scanning
---

You are a security expert analyzing code changes.

## What to Report
- SQL injection via unsanitized input
- Cross-site scripting (XSS)
- Hardcoded secrets or credentials
- Command injection vulnerabilities

## What NOT to Report
- Code style or formatting
- Performance optimizations`;
---

<Base title="Home" description="Define skills in Markdown. Compose them into agents that review every change.">
  <div class="hero">
    <p class="tagline">Your Code Is Under New Management</p>
    <p class="tagline-sub">Define skills in Markdown. Compose them into agents that review every change.</p>

    <div class="cta-buttons">
      <a href={`${base}/guide`} class="btn btn-primary">Get Started</a>
      <a href="#whats-a-skill" class="btn">What's a Skill?</a>
    </div>
  </div>

  <section class="section value-props">
    <div class="feature-grid three-col">
      <div class="feature">
        <h3>Skills are Markdown</h3>
        <p>A SKILL.md file tells Warden what to look for. No plugins, no config language. Just prose.</p>
      </div>
      <div class="feature">
        <h3>Compose what matters</h3>
        <p>Stack security, API design, accessibility, or anything else. Each skill owns one concern.</p>
      </div>
      <div class="feature">
        <h3>Run anywhere</h3>
        <p>Locally before you push, or on every PR via GitHub Actions. Same skills, same results.</p>
      </div>
    </div>
  </section>

  <section class="section skill-showcase" id="whats-a-skill">
    <h2>What's a Skill?</h2>
    <p>A skill is a Markdown file that tells Warden what to look for. You write prose, not code.</p>
    <Terminal title=".agents/skills/security-scanning/SKILL.md">
      <Code
        code={skillExample}
        lang="markdown"
        theme="vitesse-black"
      />
    </Terminal>
    <p class="skill-showcase-note">That's a trivial example, but it's a working skill. No build step. No schema. No SDK.</p>
    <p class="skill-showcase-detail">Real skills can include detailed reference material, code examples, style guides, architectural constraints, or anything else you'd put in a design doc. The prompt is the skill.</p>
  </section>

  <section class="quick-start">
    <div class="step">
      <h3>Install</h3>
      <p>Install the CLI globally.</p>
      <PackageManagerTabs
        npm="npm install -g @sentry/warden"
        pnpm="pnpm add -g @sentry/warden"
        bun="bun add -g @sentry/warden"
      />
    </div>

    <div class="step">
      <h3>Initialize</h3>
      <p>Scaffold your project with config and GitHub workflow.</p>
      <Terminal showCopy={true} copyText="warden init">
        <pre class="cli-output"><span class="cli-dim">$</span> warden init

<span class="cli-green">Created</span> warden.toml
<span class="cli-green">Created</span> .github/workflows/warden.yml

<span class="cli-bold">Next steps:</span>
  1. Add a skill: <span class="cli-cyan">warden add &lt;skill-name&gt;</span>
  2. <span class="cli-cyan">export WARDEN_ANTHROPIC_API_KEY=sk-ant-...</span>
  3. Add <span class="cli-cyan">WARDEN_ANTHROPIC_API_KEY</span> to repository secrets
     <span class="cli-dim">https://github.com/your-org/your-repo/settings/secrets/actions</span>
  4. Commit and open a PR to test</pre>
      </Terminal>
    </div>

    <div class="step">
      <h3>Add some skills</h3>
      <p>Add skills for what matters to your codebase. Local or from any GitHub repo.</p>
      <Terminal showCopy={true} copyText="warden add api-design-review --remote yourcompany/skills">
        <pre class="cli-output"><span class="cli-dim">$</span> warden add api-design-review --remote yourcompany/skills</pre>
      </Terminal>
      <p>Create your own skills or find ones driven by the community at <a href="https://skills.sh">skills.sh</a>.</p>
    </div>

    <div class="step">
      <h3>Run Locally</h3>
      <p>Catch issues before you push. Multiple skills run together, each covering its own concern.</p>
      <Terminal showCopy={false}>
        <pre class="cli-output"><span class="cli-dim">$</span> warden

Analyzing uncommitted changes...

<span class="cli-bold">FILES</span>  <span class="cli-cyan">4 files</span> <span class="cli-dim">· 6 chunks</span>
  <span class="cli-yellow">~</span> src/api/users.ts <span class="cli-dim">(2 chunks)</span>
  <span class="cli-yellow">~</span> src/db/queries.ts <span class="cli-dim">(2 chunks)</span>
  <span class="cli-green">+</span> src/auth/session.ts <span class="cli-dim">(1 chunk)</span>
  <span class="cli-yellow">~</span> src/middleware/cors.ts <span class="cli-dim">(1 chunk)</span>

┌─ <span class="cli-bold">security-scanning</span> ────────────────────────────────────── <span class="cli-dim">6.1s</span> ─┐
│ <span class="cli-bold">2 findings:</span> <span class="cli-red">●</span> 1 high  <span class="cli-yellow">●</span> 1 medium                                │
├─────────────────────────────────────────────────────────────────┤
│                                                                 │
│ <span class="cli-red">●</span> <span class="cli-bold">SQL injection via unsanitized input</span>                           │
│   <span class="cli-dim">src/db/queries.ts:42</span>                                         │
│   <span class="cli-dim">42 │</span> db.query(`SELECT * FROM users WHERE id = $&#123;id&#125;`)        │
│                                                                 │
│   User input is interpolated directly into a SQL query.         │
│   Use parameterized queries instead.                            │
│                                                                 │
│ <span class="cli-yellow">●</span> <span class="cli-bold">Hardcoded JWT secret</span>                                          │
│   <span class="cli-dim">src/auth/session.ts:8</span>                                        │
│   <span class="cli-dim"> 8 │</span> const SECRET = "sk_live_a1b2c3d4e5f6"                     │
│                                                                 │
│   Secrets should be loaded from environment variables,          │
│   not committed to source.                                      │
│                                                                 │
└─────────────────────────────────────────────────────────────────┘

┌─ <span class="cli-bold">api-design-review</span> ────────────────────────────────────── <span class="cli-dim">4.3s</span> ─┐
│ <span class="cli-bold">1 finding:</span> <span class="cli-cyan">●</span> 1 low                                                │
├─────────────────────────────────────────────────────────────────┤
│                                                                 │
│ <span class="cli-cyan">●</span> <span class="cli-bold">Missing pagination on list endpoint</span>                           │
│   <span class="cli-dim">src/api/users.ts:15</span>                                          │
│   <span class="cli-dim">15 │</span> app.get("/users", async (req, res) =&gt; &#123;                 │
│                                                                 │
│   Unbounded list endpoints can return excessive data.           │
│   Add limit/offset or cursor-based pagination.                  │
│                                                                 │
└─────────────────────────────────────────────────────────────────┘

<span class="cli-bold">SUMMARY</span>
<span class="cli-bold">3 findings:</span> <span class="cli-red">●</span> 1 high  <span class="cli-yellow">●</span> 1 medium  <span class="cli-cyan">●</span> 1 low
Analysis completed in <span class="cli-dim">6.1s</span></pre>
      </Terminal>
    </div>

    <div class="step">
      <h3>Findings on Every PR</h3>
      <p>Open a PR and Warden reviews it automatically. Findings appear as suggested changes you can apply with one click.</p>
      <div class="pr-mock">
        <div class="pr-mock-header">
          <div class="pr-mock-avatar">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="12" fill="#000"/>
              <g transform="translate(12, 12) scale(0.65) translate(-12, -12)">
                <path d="M14.2666 4.9061C15.1564 4.09409 16.5921 4.60917 16.7627 5.80162L18.1123 15.2519C18.9476 14.5758 19.6675 14.156 20.2706 13.9423C20.9583 13.6988 21.61 13.6893 22.0606 14.0459C22.5331 14.4202 22.576 15.0232 22.4131 15.5224C22.2471 16.0308 21.8525 16.5326 21.2774 16.916C20.2382 17.6088 19.1848 18.1368 17.7432 18.4863C16.3131 18.833 14.518 19 12 19C9.48202 19 7.68685 18.833 6.25679 18.4863C4.81521 18.1368 3.76183 17.6088 2.72259 16.916C2.14753 16.5326 1.75289 16.0308 1.58684 15.5224C1.42401 15.0233 1.46701 14.4202 1.93938 14.0459C2.38997 13.6893 3.04168 13.6988 3.72943 13.9423C4.33238 14.1559 5.05163 14.5761 5.88667 15.2519L7.23727 5.80162C7.40784 4.60919 8.84362 4.09419 9.73338 4.9061L11.6631 6.66686C11.854 6.84121 12.146 6.84121 12.3369 6.66686L14.2666 4.9061Z" fill="white"/>
                <path d="M12 8L13.1226 11.1094H16.7553L13.8164 13.0312L14.9389 16.1406L12 14.2188L9.06107 16.1406L10.1836 13.0312L7.24472 11.1094H10.8774L12 8Z" fill="#000"/>
              </g>
            </svg>
          </div>
          <div class="pr-mock-meta">
            <span class="pr-mock-name">warden</span>
            <span class="pr-mock-badge">bot</span>
            <span class="pr-mock-time">commented now</span>
          </div>
        </div>
        <div class="pr-mock-body">
          <div class="pr-mock-finding">
            <span class="pr-mock-severity severity-high"></span>
            <span class="pr-mock-title">SQL injection via unsanitized input</span>
          </div>
          <p class="pr-mock-desc">User input is interpolated directly into a SQL query. Use parameterized queries to prevent SQL injection attacks.</p>
          <p class="pr-mock-suggestion-label"><strong>Suggested fix:</strong> Use parameterized query</p>
          <div class="pr-mock-suggestion">
            <div class="pr-mock-suggestion-header">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8.75 1.75V5H12a.75.75 0 010 1.5H8.75v3.25a.75.75 0 01-1.5 0V6.5H4a.75.75 0 010-1.5h3.25V1.75a.75.75 0 011.5 0zM4 13a.75.75 0 000 1.5h8a.75.75 0 000-1.5H4z"/>
              </svg>
              <span>Suggested change</span>
            </div>
            <div class="pr-mock-suggestion-diff">
              <div class="pr-mock-diff-line diff-old">
                <span class="diff-marker">−</span>
                <span class="diff-content">db.query(`SELECT * FROM users WHERE id = $&#123;id&#125;`)</span>
              </div>
              <div class="pr-mock-diff-line diff-new">
                <span class="diff-marker">+</span>
                <span class="diff-content">db.query("SELECT * FROM users WHERE id = $1", [id])</span>
              </div>
            </div>
            <div class="pr-mock-suggestion-actions">
              <button class="pr-mock-commit-btn">Commit suggestion</button>
            </div>
          </div>
        </div>
        <div class="pr-mock-footer">
          <a href="#" class="pr-mock-link">View all 3 findings</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section next-steps">
    <h2>Next Steps</h2>
    <div class="next-steps-grid">
      <a href={`${base}/skill`} class="next-step-card">
        <strong>Write a Skill</strong>
        <p>Create a custom skill for your codebase</p>
      </a>
      <a href={`${base}/config`} class="next-step-card">
        <strong>Configure Triggers</strong>
        <p>Control when and where skills run</p>
      </a>
      <a href={`${base}/cli`} class="next-step-card">
        <strong>CLI Reference</strong>
        <p>Commands, options, and usage</p>
      </a>
    </div>
  </section>

</Base>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
  }

  .tagline-sub {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin: 1rem 0 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .btn-primary {
    background: #fff;
    color: #000;
  }

  .btn-primary:hover {
    opacity: 0.9;
    color: #000;
  }

  /* Value Props */
  .value-props {
    border-top: none;
    padding-top: 1rem;
  }

  .three-col {
    grid-template-columns: repeat(3, 1fr);
  }

  /* Skill Showcase */
  .skill-showcase h2 {
    border-bottom: none;
    padding-bottom: 0;
    margin-top: 0;
  }

  .skill-showcase-note {
    color: var(--text-tertiary);
    font-size: 0.9375rem;
    text-align: center;
    margin-top: 0.5rem;
  }

  .skill-showcase-detail {
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  /* Quick Start Steps */
  .quick-start {
    margin-top: 3rem;
  }

  .step {
    margin-bottom: 2.5rem;
  }

  .step:last-child {
    margin-bottom: 0;
  }

  .step h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .step > p {
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  /* PR Mock */
  .pr-mock {
    background: #000;
    border: 1px solid #21262d;
    border-radius: 6px;
    overflow: hidden;
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .pr-mock-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #0d1117;
    border-bottom: 1px solid #21262d;
  }

  .pr-mock-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
  }

  .pr-mock-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pr-mock-name {
    font-weight: 600;
    color: #8b949e;
  }

  .pr-mock-badge {
    background: #238636;
    color: #fff;
    font-size: 0.6875rem;
    padding: 0.125rem 0.375rem;
    border-radius: 9999px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pr-mock-time {
    color: #8b949e;
    font-size: 0.75rem;
  }

  .pr-mock-body {
    padding: 1rem;
  }

  .pr-mock-finding {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .pr-mock-severity {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .pr-mock-severity.severity-high {
    background: #f85149;
  }

  .pr-mock-severity.severity-medium {
    background: #d29922;
  }

  .pr-mock-title {
    font-weight: 600;
    color: #9198a1;
  }

  .pr-mock-desc {
    color: #9198a1;
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .pr-mock-suggestion-label {
    color: #9198a1;
    margin: 0 0 0.75rem;
  }

  .pr-mock-suggestion {
    background: #0d1117;
    border: 1px solid #21262d;
    border-radius: 6px;
    overflow: hidden;
  }

  .pr-mock-suggestion-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #161b22;
    border-bottom: 1px solid #21262d;
    font-size: 0.75rem;
    font-weight: 600;
    color: #8b949e;
  }

  .pr-mock-suggestion-diff {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.6;
  }

  .pr-mock-diff-line {
    display: flex;
    padding: 0 0.75rem;
  }

  .pr-mock-diff-line.diff-old {
    background: rgba(248, 81, 73, 0.15);
  }

  .pr-mock-diff-line.diff-new {
    background: rgba(63, 185, 80, 0.15);
  }

  .diff-marker {
    width: 1.5rem;
    flex-shrink: 0;
    text-align: center;
    user-select: none;
  }

  .diff-content {
    flex: 1;
    white-space: pre;
  }

  .diff-old .diff-marker { color: #f85149; }
  .diff-old .diff-content { color: #ffa198; }

  .diff-new .diff-marker { color: #3fb950; }
  .diff-new .diff-content { color: #7ee787; }

  .pr-mock-suggestion-actions {
    display: flex;
    justify-content: flex-end;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid #21262d;
    background: #161b22;
  }

  .pr-mock-commit-btn {
    background: #238636;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
  }

  .pr-mock-commit-btn:hover {
    background: #2ea043;
  }

  .pr-mock-footer {
    padding: 0.75rem 1rem;
    border-top: 1px solid #30363d;
  }

  .pr-mock-link {
    font-size: 0.8125rem;
    color: #58a6ff;
  }

  .pr-mock-link:hover {
    text-decoration: underline;
  }

  /* Next Steps */
  .next-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .next-step-card {
    display: block;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s ease, background 0.15s ease;
    color: inherit;
  }

  .next-step-card:hover {
    border-color: var(--border-strong);
    background: rgba(255, 255, 255, 0.04);
    color: inherit;
  }

  .next-step-card strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .next-step-card p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .next-step-card code {
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .tagline {
      font-size: 1.25rem;
      letter-spacing: 0.02em;
    }

    .three-col {
      grid-template-columns: 1fr;
    }

    .next-steps-grid {
      grid-template-columns: 1fr;
    }

    .step > p {
      margin-left: 0;
    }
  }
</style>
