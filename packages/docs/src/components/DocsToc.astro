---
interface TocItem {
  href: string;
  title: string;
  variant?: 'default' | 'code';
}

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

<nav class="docs-toc" data-docs-toc transition:name="page-toc">
  <details>
    <summary class="docs-toc-summary">
      <span class="docs-toc-summary-main">
        <span class="docs-toc-progress" aria-hidden="true"></span>
        <span class="docs-toc-summary-copy">
          <span class="docs-toc-summary-eyebrow">On this page</span>
          <span
            class:list={[
              'docs-toc-summary-title',
              { 'docs-toc-summary-title-code': items[0]?.variant === 'code' },
            ]}
            data-toc-summary-title
          >
            {items[0]?.title ?? 'Overview'}
          </span>
        </span>
      </span>
      <span class="docs-toc-summary-chevron" aria-hidden="true"></span>
    </summary>
    <div class="docs-toc-panel">
      <ul>
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              data-toc-variant={item.variant ?? 'default'}
            >
              {item.variant === 'code' ? (
                <span class="docs-toc-link-pill docs-toc-link-pill-code">{item.title}</span>
              ) : item.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </details>
</nav>

<script>
  type DocsTocElement = HTMLElement & {
    __tocAbort?: AbortController;
  };
  type TocSection = {
    href: string;
    link: HTMLAnchorElement;
    section: HTMLElement;
    title: string;
    variant: 'default' | 'code';
  };

  const DOCS_TOC_DESKTOP_QUERY = '(min-width: 1380px)';

  function initDocsToc(toc: DocsTocElement) {
    toc.__tocAbort?.abort();

    const abortController = new AbortController();
    toc.__tocAbort = abortController;

    const details = toc.querySelector('details');
    const summary = toc.querySelector('summary');
    const panel = toc.querySelector('.docs-toc-panel');
    const summaryTitle = toc.querySelector('[data-toc-summary-title]');
    const desktopQuery = window.matchMedia(DOCS_TOC_DESKTOP_QUERY);
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (
      !(details instanceof HTMLDetailsElement)
      || !(summary instanceof HTMLElement)
      || !(panel instanceof HTMLElement)
      || !(summaryTitle instanceof HTMLElement)
    ) {
      return;
    }

    const links = Array.from(toc.querySelectorAll('a[href^="#"]'));
    const sections = links
      .map((link) => {
        const href = link.getAttribute('href');
        if (!href) {
          return null;
        }

        const section = document.querySelector(href);
        if (!(section instanceof HTMLElement)) {
          return null;
        }

        return {
          href,
          link,
          section,
          title: (link.textContent || '').trim(),
          variant: link.dataset.tocVariant === 'code' ? 'code' : 'default',
        };
      })
      .filter((entry): entry is TocSection => entry !== null);

    if (sections.length === 0) {
      return;
    }

    let frame = 0;
    let panelAnimation: Animation | null = null;

    function finishPanelState(isOpen: boolean) {
      details.open = isOpen;
      panel.dataset.open = isOpen ? 'true' : 'false';
      panel.style.height = isOpen ? 'auto' : '0px';
      panel.style.overflow = isOpen ? 'visible' : 'hidden';
      toc.dataset.tocState = desktopQuery.matches ? 'desktop' : (isOpen ? 'expanded' : 'collapsed');
    }

    function animatePanel(isOpen: boolean): Promise<void> {
      panelAnimation?.cancel();

      if (desktopQuery.matches) {
        finishPanelState(true);
        return Promise.resolve();
      }

      if (reducedMotionQuery.matches) {
        finishPanelState(isOpen);
        return Promise.resolve();
      }

      const startHeight = panel.getBoundingClientRect().height;
      details.open = true;
      panel.dataset.open = isOpen ? 'true' : 'false';
      panel.style.overflow = 'hidden';
      panel.style.height = `${startHeight}px`;

      const endHeight = isOpen ? panel.scrollHeight : 0;
      return new Promise((resolve) => {
        panelAnimation = panel.animate(
          [{ height: `${startHeight}px` }, { height: `${endHeight}px` }],
          {
            duration: 220,
            easing: 'cubic-bezier(0.32, 0.72, 0, 1)',
            fill: 'forwards',
          }
        );

        panelAnimation.onfinish = () => {
          finishPanelState(isOpen);
          panelAnimation = null;
          resolve();
        };

        panelAnimation.oncancel = () => {
          panelAnimation = null;
          resolve();
        };
      });
    }

    function waitForLayout(): Promise<void> {
      return new Promise((resolve) => {
        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => resolve());
        });
      });
    }

    function updateHash(hash: string) {
      const url = new URL(window.location.href);

      if (url.hash === hash) {
        history.replaceState(history.state, '', hash);
        return;
      }

      history.pushState(history.state, '', hash);
    }

    async function navigateToSection(entry: TocSection) {
      await animatePanel(false);
      await waitForLayout();

      const top = Math.max(
        window.scrollY + entry.section.getBoundingClientRect().top - getScrollOffset(),
        0
      );

      updateHash(entry.href);
      window.scrollTo({
        top,
        behavior: reducedMotionQuery.matches ? 'auto' : 'smooth',
      });

      requestSync();
    }

    function syncTocMode() {
      finishPanelState(desktopQuery.matches);
    }

    function getScrollOffset() {
      const nav = document.querySelector('.nav');
      const navHeight = nav instanceof HTMLElement ? nav.getBoundingClientRect().height : 0;
      const tocHeight = desktopQuery.matches ? 0 : summary.getBoundingClientRect().height;
      return navHeight + tocHeight + 20;
    }

    function syncActiveLink() {
      frame = 0;

      const offset = getScrollOffset();
      let active = sections[0];

      for (const entry of sections) {
        if (entry.section.getBoundingClientRect().top <= offset) {
          active = entry;
        }
      }

      const activeRect = active.section.getBoundingClientRect();
      const activeHeadingVisible = activeRect.top < window.innerHeight && activeRect.bottom > offset;

      if (!activeHeadingVisible) {
        const nextVisibleHeading = sections.find((entry) => {
          const rect = entry.section.getBoundingClientRect();
          return rect.top < window.innerHeight && rect.bottom > offset;
        });

        if (nextVisibleHeading) {
          active = nextVisibleHeading;
        }
      }

      summaryTitle.textContent = active.title;
      summaryTitle.classList.toggle('docs-toc-summary-title-code', active.variant === 'code');

      const firstTop = window.scrollY + sections[0].section.getBoundingClientRect().top - offset;
      const lastSection = sections[sections.length - 1].section;
      const lastBottom = window.scrollY + lastSection.getBoundingClientRect().top + lastSection.offsetHeight - offset;
      const rawProgress = Math.min(Math.max((window.scrollY - firstTop) / Math.max(lastBottom - firstTop, 1), 0), 1);
      const pageBottomReached = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
      const progress = pageBottomReached ? 1 : rawProgress;
      toc.style.setProperty('--docs-toc-progress', `${progress * 360}deg`);

      links.forEach((link) => {
        const isActive = link === active.link;
        link.classList.toggle('active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'location');
          return;
        }

        link.removeAttribute('aria-current');
      });
    }

    function requestSync() {
      if (frame !== 0) {
        return;
      }

      frame = window.requestAnimationFrame(syncActiveLink);
    }

    syncTocMode();
    requestSync();

    summary.addEventListener('click', (event) => {
      if (desktopQuery.matches) {
        return;
      }

      event.preventDefault();
      animatePanel(!details.open);
    }, { signal: abortController.signal });

    desktopQuery.addEventListener('change', syncTocMode, { signal: abortController.signal });
    reducedMotionQuery.addEventListener('change', syncTocMode, { signal: abortController.signal });
    window.addEventListener('scroll', requestSync, { passive: true, signal: abortController.signal });
    window.addEventListener('resize', requestSync, { passive: true, signal: abortController.signal });
    window.addEventListener('hashchange', requestSync, { signal: abortController.signal });

    links.forEach((link) => {
      link.addEventListener('click', async (event) => {
        if (desktopQuery.matches) {
          return;
        }

        const href = link.getAttribute('href');
        const target = href ? sections.find((section) => section.href === href) : undefined;
        if (!target) {
          return;
        }

        event.preventDefault();
        await navigateToSection(target);
      }, { signal: abortController.signal });
    });
  }

  function initAllDocsTocs() {
    document.querySelectorAll('[data-docs-toc]').forEach((element) => {
      initDocsToc(element as DocsTocElement);
    });
  }

  initAllDocsTocs();
  document.addEventListener('astro:page-load', initAllDocsTocs);
  document.addEventListener('astro:before-preparation', () => {
    document.querySelectorAll('[data-docs-toc]').forEach((element) => {
      (element as DocsTocElement).__tocAbort?.abort();
    });
  });
</script>

<style is:global>
  .docs-toc {
    --docs-toc-accent: var(--link-hover);
    --docs-toc-progress: 0deg;
    position: sticky;
    top: 4.25rem;
    z-index: 30;
    margin: 0;
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    padding: 0 1.5rem;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .docs-toc details {
    display: block;
  }

  .docs-toc summary {
    list-style: none;
  }

  .docs-toc summary::-webkit-details-marker {
    display: none;
  }

  .docs-toc-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.875rem;
    cursor: pointer;
    color: var(--text);
    min-height: 3rem;
  }

  .docs-toc-summary-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .docs-toc-progress {
    position: relative;
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 999px;
    background: conic-gradient(var(--docs-toc-accent) var(--docs-toc-progress), rgba(255, 255, 255, 0.12) 0deg);
  }

  .docs-toc-progress::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: inherit;
    background: rgba(7, 7, 7, 0.92);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .docs-toc-summary-copy {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .docs-toc-summary-eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text-secondary);
  }

  .docs-toc-summary-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .docs-toc-summary-title-code {
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.83rem;
    line-height: 1.2;
    padding: 0.28rem 0.45rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
  }

  .docs-toc-summary-chevron {
    width: 0.55rem;
    height: 0.55rem;
    border-right: 1.5px solid var(--text-secondary);
    border-bottom: 1.5px solid var(--text-secondary);
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .docs-toc details[open] .docs-toc-summary-chevron {
    transform: rotate(225deg);
    border-color: var(--docs-toc-accent);
  }

  .docs-toc-panel {
    height: 0;
    overflow: hidden;
  }

  .docs-toc ul {
    margin: 0 0 0.75rem;
    padding-left: 0;
    list-style: none;
    opacity: 0;
    transform: translateY(-0.2rem);
  }

  .docs-toc-panel[data-open="true"] > ul,
  .docs-toc details[open] .docs-toc-panel > ul {
    opacity: 1;
    transform: translateY(0);
  }

  .docs-toc-panel > ul {
    padding-left: 0;
  }

  .docs-toc li {
    margin: 0.2rem 0;
    line-height: 1.4;
  }

  .docs-toc a {
    display: block;
    padding: 0.45rem 0 0.45rem 0.9rem;
    border-left: 1px solid transparent;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .docs-toc a[data-toc-variant="code"] {
    padding-top: 0.18rem;
    padding-bottom: 0.18rem;
  }

  .docs-toc a:hover {
    color: var(--text);
    border-left-color: rgba(255, 255, 255, 0.18);
  }

  .docs-toc a.active {
    color: var(--docs-toc-accent);
    border-left-color: var(--docs-toc-accent);
  }

  .docs-toc-link-pill {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    color: inherit;
  }

  .docs-toc-link-pill-code {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.25;
  }

  .docs-toc a:hover .docs-toc-link-pill-code {
    background: rgba(255, 255, 255, 0.05);
  }

  .docs-toc a.active .docs-toc-link-pill-code {
    background: rgba(59, 158, 255, 0.08);
  }

  @media (min-width: 1380px) {
    .docs-toc {
      position: absolute;
      top: 0;
      left: calc(100% + 2.5rem);
      width: 15rem;
      height: 100%;
      margin: 0;
      padding: 0;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      z-index: 110;
    }

    .docs-toc summary {
      pointer-events: none;
    }

    .docs-toc > details {
      position: sticky;
      top: calc(var(--nav-scroll-offset, 5rem) + 1rem);
      display: block;
    }

    .docs-toc-summary {
      min-height: 0;
      margin-bottom: 0.5rem;
    }

    .docs-toc-progress,
    .docs-toc-summary-title,
    .docs-toc-summary-chevron {
      display: none;
    }

    .docs-toc-summary-copy {
      display: block;
    }

    .docs-toc-summary-eyebrow {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
    }

    .docs-toc ul {
      margin: 0;
      opacity: 1;
      transform: none;
    }

    .docs-toc li {
      margin: 0;
    }

  }

  @media (max-width: 640px) {
    .docs-toc {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  .docs-toc[data-toc-state="collapsed"] {
    view-transition-name: none;
  }

  .docs-toc[data-toc-state="expanded"],
  .docs-toc[data-toc-state="desktop"] {
    view-transition-name: page-toc;
  }

  @media (prefers-reduced-motion: no-preference) {
    .docs-toc ul {
      transition: opacity 0.18s ease, transform 0.18s ease;
    }

    .docs-toc-summary-chevron {
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
  }
</style>
