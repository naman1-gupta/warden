---
const skills = [
  "security-scanning",
  "api-design-review",
  "architecture-review",
  "dependency-review",
  "test-coverage",
  "auth-hardening",
  "performance-guardrails",
  "error-handling",
];
const desktopSkillLayout = [
  { side: "right", inset: "0rem" },
  { side: "left", inset: "0rem" },
  { side: "right", inset: "1.1rem" },
  { side: "left", inset: "0.55rem" },
  { side: "right", inset: "2rem" },
  { side: "left", inset: "1.45rem" },
  { side: "left", inset: "2.25rem" },
  { side: "right", inset: "0.45rem" },
];
const connectorCount = skills.length + 2;
---

<section class="hero-flow" aria-label="Warden trigger flow">
  <div class="hero-flow-bg" aria-hidden="true"></div>
  <svg class="hero-flow-lines" preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <mask id="hero-flow-dash-mask" maskUnits="userSpaceOnUse" maskContentUnits="userSpaceOnUse">
        {Array.from({ length: connectorCount }).map((_, idx) => (
          <path class="hero-flow-mask-path" data-mask-line={idx}></path>
        ))}
      </mask>
    </defs>
    {Array.from({ length: connectorCount }).map((_, idx) => (
      <path class="hero-flow-line" data-line={idx}></path>
    ))}
    <g class="hero-flow-trails" mask="url(#hero-flow-dash-mask)">
      {Array.from({ length: connectorCount }).map((_, idx) => (
        <path
          class="hero-flow-trail"
          data-trail={idx}
          style={`--trail-start:${-(idx * 30)}px`}
        ></path>
      ))}
    </g>
  </svg>

  <div class="hero-bug-stage" aria-hidden="true">
  </div>

  <div class="hero-flow-grid">
    <div class="hero-flow-column hero-flow-column-skills">
      <span class="hero-flow-label">
        <span class="hero-flow-label-desktop">Skills</span>
        <span class="hero-flow-label-mobile">Define skills in Markdown.</span>
      </span>
      <div class="hero-flow-skills-clip">
        <div class="hero-flow-skills-list">
          {skills.map((skill, index) => (
            <div
              class="hero-skill-card"
              data-anchor={`skill-${index}`}
              data-side={desktopSkillLayout[index % desktopSkillLayout.length].side}
              style={`--skill-inset:${desktopSkillLayout[index % desktopSkillLayout.length].inset}`}
            >
              <span class="hero-border-shimmer" aria-hidden="true">
                <span class="hero-border-base"></span>
                <span class="hero-border-shimmer-spot"></span>
              </span>
              <span class="hero-skill-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M7 3.75h6.5L18.25 8.5V20a1.25 1.25 0 0 1-1.25 1.25H7A1.25 1.25 0 0 1 5.75 20V5A1.25 1.25 0 0 1 7 3.75Z" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M13.5 3.75V8.5h4.75" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M8.5 12.25h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  <path d="M8.5 15.75h4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
              </span>
              <code>{skill}</code>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="hero-flow-column hero-flow-column-center">
      <div class="warden-node" data-anchor="warden" aria-label="Warden">
        <span class="hero-border-shimmer" aria-hidden="true">
          <span class="hero-border-base"></span>
          <span class="hero-border-shimmer-spot"></span>
        </span>
        <span class="warden-shield">
          <span class="warden-eye">
            <span class="warden-iris warden-pupil"></span>
          </span>
        </span>
      </div>
    </div>

    <div class="hero-flow-column hero-flow-column-output">
      <span class="hero-flow-label">
        <span class="hero-flow-label-desktop">Run before you push</span>
        <span class="hero-flow-label-mobile">Compose them into agents.</span>
      </span>
      <div class="hero-cli" data-anchor="cli">
        <span class="hero-border-shimmer" aria-hidden="true">
          <span class="hero-border-base"></span>
          <span class="hero-border-shimmer-spot"></span>
        </span>
        <div class="hero-cli-header hero-shimmer-divider hero-shimmer-divider-bottom" aria-hidden="true">
          <span class="hero-cli-dot dot-red"></span>
          <span class="hero-cli-dot dot-yellow"></span>
          <span class="hero-cli-dot dot-green"></span>
        </div>
        <div class="hero-cli-body">
          <span class="cli-dim">$</span> warden
        </div>
      </div>

      <span class="hero-flow-label hero-flow-label-pr">
        <span class="hero-flow-label-desktop">Every pull request</span>
        <span class="hero-flow-label-mobile">Compose them into agents that review every change.</span>
      </span>
      <div class="hero-pr-clip">
        <div class="pr-mock" data-anchor="pr">
          <span class="hero-border-shimmer" aria-hidden="true">
            <span class="hero-border-base"></span>
            <span class="hero-border-shimmer-spot"></span>
          </span>
          <div class="pr-mock-header hero-shimmer-divider hero-shimmer-divider-bottom">
            <div class="pr-mock-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="12" fill="#000"></circle>
                <g transform="translate(12, 12) scale(0.65) translate(-12, -12)">
                  <path d="M14.2666 4.9061C15.1564 4.09409 16.5921 4.60917 16.7627 5.80162L18.1123 15.2519C18.9476 14.5758 19.6675 14.156 20.2706 13.9423C20.9583 13.6988 21.61 13.6893 22.0606 14.0459C22.5331 14.4202 22.576 15.0232 22.4131 15.5224C22.2471 16.0308 21.8525 16.5326 21.2774 16.916C20.2382 17.6088 19.1848 18.1368 17.7432 18.4863C16.3131 18.833 14.518 19 12 19C9.48202 19 7.68685 18.833 6.25679 18.4863C4.81521 18.1368 3.76183 17.6088 2.72259 16.916C2.14753 16.5326 1.75289 16.0308 1.58684 15.5224C1.42401 15.0233 1.46701 14.4202 1.93938 14.0459C2.38997 13.6893 3.04168 13.6988 3.72943 13.9423C4.33238 14.1559 5.05163 14.5761 5.88667 15.2519L7.23727 5.80162C7.40784 4.60919 8.84362 4.09419 9.73338 4.9061L11.6631 6.66686C11.854 6.84121 12.146 6.84121 12.3369 6.66686L14.2666 4.9061Z" fill="white"></path>
                  <path d="M12 8L13.1226 11.1094H16.7553L13.8164 13.0312L14.9389 16.1406L12 14.2188L9.06107 16.1406L10.1836 13.0312L7.24472 11.1094H10.8774L12 8Z" fill="#000"></path>
                </g>
              </svg>
            </div>
            <div class="pr-mock-meta">
              <span class="pr-mock-name">warden</span>
              <span class="pr-mock-badge">bot</span>
              <span class="pr-mock-time">commented now</span>
            </div>
          </div>
          <div class="pr-mock-body">
            <div class="pr-mock-finding">
              <span class="pr-mock-severity severity-high"></span>
              <span class="pr-mock-title">SQL injection via unsanitized input</span>
            </div>
            <p class="pr-mock-desc">User input is interpolated directly into a SQL query. Use parameterized queries to prevent SQL injection attacks.</p>
            <p class="pr-mock-suggestion-label"><strong>Suggested fix:</strong> Use parameterized query</p>
            <div class="pr-mock-suggestion">
              <span class="hero-border-shimmer" aria-hidden="true">
                <span class="hero-border-base"></span>
                <span class="hero-border-shimmer-spot"></span>
              </span>
              <div class="pr-mock-suggestion-header hero-shimmer-divider hero-shimmer-divider-bottom">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8.75 1.75V5H12a.75.75 0 010 1.5H8.75v3.25a.75.75 0 01-1.5 0V6.5H4a.75.75 0 010-1.5h3.25V1.75a.75.75 0 011.5 0zM4 13a.75.75 0 000 1.5h8a.75.75 0 000-1.5H4z"/>
                </svg>
                <span>Suggested change</span>
              </div>
              <div class="pr-mock-suggestion-diff">
                <div class="pr-mock-diff-line diff-old">
                  <span class="diff-marker">-</span>
                  <span class="diff-content">db.query(`SELECT * FROM users WHERE id = $&#123;id&#125;`)</span>
                </div>
                <div class="pr-mock-diff-line diff-new">
                  <span class="diff-marker">+</span>
                  <span class="diff-content">db.query("SELECT * FROM users WHERE id = $1", [id])</span>
                </div>
              </div>
              <div class="pr-mock-suggestion-actions hero-shimmer-divider hero-shimmer-divider-top">
                <button class="pr-mock-commit-btn">Commit suggestion</button>
              </div>
            </div>
          </div>
          <div class="pr-mock-footer hero-shimmer-divider hero-shimmer-divider-top">
            <a href="#" class="pr-mock-link">View all 3 findings</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function heroFlowPoint(el, side, rootRect, offset = 0) {
    const rect = el.getBoundingClientRect();
    if (side === "top") {
      return {
        x: rect.left - rootRect.left + rect.width * (0.5 + offset),
        y: rect.top - rootRect.top,
      };
    }
    if (side === "bottom") {
      return {
        x: rect.left - rootRect.left + rect.width * (0.5 + offset),
        y: rect.bottom - rootRect.top,
      };
    }
    if (side === "left") {
      return {
        x: rect.left - rootRect.left,
        y: rect.top - rootRect.top + rect.height * (0.5 + offset),
      };
    }
    return {
      x: rect.right - rootRect.left,
      y: rect.top - rootRect.top + rect.height * (0.5 + offset),
    };
  }

  function heroFlowCirclePoint(el, rootRect, angleDeg) {
    const rect = el.getBoundingClientRect();
    const cx = rect.left - rootRect.left + rect.width / 2;
    const cy = rect.top - rootRect.top + rect.height / 2;
    const radius = (Math.min(rect.width, rect.height) / 2) - 0.5;
    const angle = (angleDeg * Math.PI) / 180;
    return {
      x: cx + radius * Math.cos(angle),
      y: cy + radius * Math.sin(angle),
    };
  }

  function heroFlowCurve(a, b) {
    const dx = Math.abs(b.x - a.x);
    const ctrl = Math.max(26, dx * 0.42);
    const dir = b.x >= a.x ? 1 : -1;
    const c1x = a.x + (dir * ctrl);
    const c2x = b.x - (dir * ctrl);
    return `M ${a.x} ${a.y} C ${c1x} ${a.y} ${c2x} ${b.y} ${b.x} ${b.y}`;
  }

  function heroFlowFan(a, b) {
    const midY = a.y + (b.y - a.y) * 0.58;
    return `M ${a.x} ${a.y} C ${a.x} ${midY} ${b.x} ${midY} ${b.x} ${b.y}`;
  }

  function heroFlowVertical(a, b) {
    const midY = (a.y + b.y) / 2;
    return `M ${a.x} ${a.y} C ${a.x} ${midY} ${b.x} ${midY} ${b.x} ${b.y}`;
  }

  function setupHeroFlows() {
    document.querySelectorAll(".hero-flow").forEach((flow) => {
      if (flow.__heroFlowCleanup) {
        flow.__heroFlowCleanup();
      }

      const svg = flow.querySelector(".hero-flow-lines");
      const lines = Array.from(flow.querySelectorAll("[data-line]"));
      const skills = Array.from(flow.querySelectorAll("[data-anchor^='skill-']"));
      const warden = flow.querySelector("[data-anchor='warden']");
      const shield = flow.querySelector(".warden-shield");
      const eye = flow.querySelector(".warden-eye");
      const pupil = flow.querySelector(".warden-pupil");
      const bugStage = flow.querySelector(".hero-bug-stage");
      const cli = flow.querySelector("[data-anchor='cli']");
      const pr = flow.querySelector("[data-anchor='pr']");
      const trails = Array.from(flow.querySelectorAll("[data-trail]"));
      const maskLines = Array.from(flow.querySelectorAll("[data-mask-line]"));
      const outputTrailPalette = ["#22d3ee", "#facc15", "#f87171", "#4ade80"];
      const skillTrailPalette = ["#b8f2fb", "#fff2b8", "#ffd4cf", "#cdf5d8"];
      const bugPalette = ["#f87171"];

      if (!svg || skills.length < 3 || !warden || !shield || !eye || !pupil || !bugStage || !cli || !pr) {
        return;
      }

      const bugStageHome = bugStage.parentNode;
      const bugStageHomeNextSibling = bugStage.nextSibling;
      document.body.appendChild(bugStage);

      const motionEnabled = window.matchMedia("(pointer: fine)").matches;
      const touchSwipeEnabled = window.matchMedia("(hover: none) and (pointer: coarse)").matches;
      const clampToCircle = (dx, dy, maxRadius) => {
        const distance = Math.hypot(dx, dy);
        if (distance <= maxRadius || distance === 0) {
          return { x: dx, y: dy };
        }
        const ratio = maxRadius / distance;
        return { x: dx * ratio, y: dy * ratio };
      };
      const lerp = (start, end, amount) => start + ((end - start) * amount);
      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
      const projectToCircleBorder = (x, y) => {
        const radius = Math.max(Math.hypot(x, y), 0.0001);
        return { x: x / radius, y: y / radius };
      };

      let update = () => {};
      let rafId = 0;
      let shimmerDirX = 1;
      let shimmerDirY = 0;
      let nodeX = 0;
      let nodeY = 0;
      let nodeTargetX = 0;
      let nodeTargetY = 0;
      let nodeBorderX = 50;
      let nodeBorderY = 50;
      let nodeTargetBorderX = 50;
      let nodeTargetBorderY = 50;
      let nodeHighlightX = 50;
      let nodeHighlightY = 50;
      let nodeTargetHighlightX = 50;
      let nodeTargetHighlightY = 50;
      let shieldX = 0;
      let shieldY = 0;
      let shieldTargetX = 0;
      let shieldTargetY = 0;
      let eyeX = 0;
      let eyeY = 0;
      let eyeTargetX = 0;
      let eyeTargetY = 0;
      let eyeAimOverrideActive = false;
      let eyeAimOverrideX = 0;
      let eyeAimOverrideY = 0;
      let blinkScheduleTimerId = 0;
      let blinkFollowupTimerId = 0;
      let blinkResetTimerId = 0;
      let bugScheduleTimerId = 0;
      let bugActorSerial = 0;
      let lastPointerClientX = window.innerWidth / 2;
      let lastPointerClientY = window.innerHeight / 2;
      let updateDefenseScene = () => {};
      const activeBugActors = [];
      const skillMotionStates = skills.map((skillEl) => ({
        el: skillEl,
        x: 0,
        y: 0,
        targetX: 0,
        targetY: 0,
        borderX: 50,
        borderY: 50,
        targetBorderX: 50,
        targetBorderY: 50,
      }));
      const panelMotionStates = [cli, pr].map((panelEl) => ({
        el: panelEl,
        borderX: 50,
        borderY: 50,
        targetBorderX: 50,
        targetBorderY: 50,
      }));
      const cliPanelMotionState = panelMotionStates.find((state) => state.el === cli) ?? null;

      const applySkillMotion = () => {
        skillMotionStates.forEach((state) => {
          state.el.style.setProperty("--skill-offset-x", `${state.x.toFixed(2)}px`);
          state.el.style.setProperty("--skill-offset-y", `${state.y.toFixed(2)}px`);
          state.el.style.setProperty("--skill-border-x", `${state.borderX.toFixed(2)}%`);
          state.el.style.setProperty("--skill-border-y", `${state.borderY.toFixed(2)}%`);
        });
        panelMotionStates.forEach((state) => {
          state.el.style.setProperty("--box-shimmer-x", `${state.borderX.toFixed(2)}%`);
          state.el.style.setProperty("--box-shimmer-y", `${state.borderY.toFixed(2)}%`);
        });
      };

      const applyMascotMotion = () => {
        const nodeShimmerDistance = Math.min(
          1,
          Math.hypot((nodeBorderX - 50) / 46, (nodeBorderY - 50) / 46),
        );
        const nodeShimmerMix = nodeShimmerDistance * nodeShimmerDistance * (3 - (2 * nodeShimmerDistance));
        const nodeCircleShimmerScale = 0.5 + (nodeShimmerMix * 0.5);
        const cliShimmerDistance = cliPanelMotionState
          ? Math.min(
            1,
            Math.hypot((cliPanelMotionState.borderX - 50) / 48, (cliPanelMotionState.borderY - 50) / 42),
          )
          : 0;
        const cliDotShimmerScale = 0.2 + (cliShimmerDistance * 0.8);
        warden.style.setProperty("--node-x", `${nodeX.toFixed(2)}px`);
        warden.style.setProperty("--node-y", `${nodeY.toFixed(2)}px`);
        warden.style.setProperty("--node-shimmer-x", `${nodeBorderX.toFixed(2)}%`);
        warden.style.setProperty("--node-shimmer-y", `${nodeBorderY.toFixed(2)}%`);
        warden.style.setProperty("--node-highlight-x", `${nodeHighlightX.toFixed(2)}%`);
        warden.style.setProperty("--node-highlight-y", `${nodeHighlightY.toFixed(2)}%`);
        warden.style.setProperty("--node-circle-shimmer-scale", nodeCircleShimmerScale.toFixed(3));
        cli.style.setProperty("--cli-dot-shimmer-scale", cliDotShimmerScale.toFixed(3));
        warden.style.setProperty("--shield-x", `${shieldX.toFixed(2)}px`);
        warden.style.setProperty("--shield-y", `${shieldY.toFixed(2)}px`);
        shield.style.setProperty("--shield-x", `${shieldX.toFixed(2)}px`);
        shield.style.setProperty("--shield-y", `${shieldY.toFixed(2)}px`);
        eye.style.setProperty("--eye-x", `${eyeX.toFixed(2)}px`);
        eye.style.setProperty("--eye-y", `${eyeY.toFixed(2)}px`);
        applySkillMotion();
        update();
        updateDefenseScene();
      };

      const animateMascotMotion = () => {
        const ease = 0.16;
        const skillBorderEase = 0.28;
        const nodeShimmerEase = 0.46;
        const activeEyeTargetX = eyeAimOverrideActive ? eyeAimOverrideX : eyeTargetX;
        const activeEyeTargetY = eyeAimOverrideActive ? eyeAimOverrideY : eyeTargetY;
        nodeX += (nodeTargetX - nodeX) * ease;
        nodeY += (nodeTargetY - nodeY) * ease;
        nodeBorderX += (nodeTargetBorderX - nodeBorderX) * nodeShimmerEase;
        nodeBorderY += (nodeTargetBorderY - nodeBorderY) * nodeShimmerEase;
        nodeHighlightX += (nodeTargetHighlightX - nodeHighlightX) * nodeShimmerEase;
        nodeHighlightY += (nodeTargetHighlightY - nodeHighlightY) * nodeShimmerEase;
        shieldX += (shieldTargetX - shieldX) * ease;
        shieldY += (shieldTargetY - shieldY) * ease;
        eyeX += (activeEyeTargetX - eyeX) * ease;
        eyeY += (activeEyeTargetY - eyeY) * ease;
        skillMotionStates.forEach((state) => {
          state.x += (state.targetX - state.x) * ease;
          state.y += (state.targetY - state.y) * ease;
          state.borderX += (state.targetBorderX - state.borderX) * skillBorderEase;
          state.borderY += (state.targetBorderY - state.borderY) * skillBorderEase;
        });
        panelMotionStates.forEach((state) => {
          state.borderX += (state.targetBorderX - state.borderX) * skillBorderEase;
          state.borderY += (state.targetBorderY - state.borderY) * skillBorderEase;
        });
        applyMascotMotion();

        const settled =
          Math.abs(nodeTargetX - nodeX) < 0.06
          && Math.abs(nodeTargetY - nodeY) < 0.06
          && Math.abs(nodeTargetBorderX - nodeBorderX) < 0.06
          && Math.abs(nodeTargetBorderY - nodeBorderY) < 0.06
          && Math.abs(nodeTargetHighlightX - nodeHighlightX) < 0.06
          && Math.abs(nodeTargetHighlightY - nodeHighlightY) < 0.06
          && Math.abs(shieldTargetX - shieldX) < 0.06
          && Math.abs(shieldTargetY - shieldY) < 0.06
          && Math.abs(activeEyeTargetX - eyeX) < 0.06
          && Math.abs(activeEyeTargetY - eyeY) < 0.06
          && skillMotionStates.every((state) =>
            Math.abs(state.targetX - state.x) < 0.06
            && Math.abs(state.targetY - state.y) < 0.06
            && Math.abs(state.targetBorderX - state.borderX) < 0.06
            && Math.abs(state.targetBorderY - state.borderY) < 0.06
          )
          && panelMotionStates.every((state) =>
            Math.abs(state.targetBorderX - state.borderX) < 0.06
            && Math.abs(state.targetBorderY - state.borderY) < 0.06
          );

        if (settled) {
          nodeX = nodeTargetX;
          nodeY = nodeTargetY;
          nodeBorderX = nodeTargetBorderX;
          nodeBorderY = nodeTargetBorderY;
          nodeHighlightX = nodeTargetHighlightX;
          nodeHighlightY = nodeTargetHighlightY;
          shieldX = shieldTargetX;
          shieldY = shieldTargetY;
          eyeX = activeEyeTargetX;
          eyeY = activeEyeTargetY;
          applyMascotMotion();
          rafId = 0;
          return;
        }

        rafId = window.requestAnimationFrame(animateMascotMotion);
      };

      const requestMascotMotion = () => {
        if (rafId !== 0) return;
        rafId = window.requestAnimationFrame(animateMascotMotion);
      };

      const createBugActorElements = () => {
        const laserEl = document.createElement("div");
        laserEl.className = "hero-eye-laser";

        const bugEl = document.createElement("div");
        bugEl.className = "hero-bug";
        bugEl.innerHTML = `
          <span class="hero-bug-flash"></span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="hero-bug-svg lucide lucide-bug-icon lucide-bug"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.45"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <g class="hero-bug-shell">
              <path d="M12 20v-9"></path>
              <path d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"></path>
              <path d="M14.12 3.88 16 2"></path>
              <path d="m8 2 1.88 1.88"></path>
              <path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"></path>
            </g>
            <g class="hero-bug-legs hero-bug-legs-right">
              <path d="M21 21a4 4 0 0 0-3.81-4"></path>
              <path d="M21 5a4 4 0 0 1-3.55 3.97"></path>
              <path d="M22 13h-4"></path>
            </g>
            <g class="hero-bug-legs hero-bug-legs-left">
              <path d="M3 21a4 4 0 0 1 3.81-4"></path>
              <path d="M3 5a4 4 0 0 0 3.55 3.97"></path>
              <path d="M6 13H2"></path>
            </g>
          </svg>
        `;
        bugStage.append(laserEl, bugEl);

        return { laserEl, bugEl };
      };

      const clearBugActorTimers = (actor) => {
        if (actor.aimTimerId !== 0) {
          window.clearTimeout(actor.aimTimerId);
          actor.aimTimerId = 0;
        }
        if (actor.hitTimerId !== 0) {
          window.clearTimeout(actor.hitTimerId);
          actor.hitTimerId = 0;
        }
        if (actor.cleanupTimerId !== 0) {
          window.clearTimeout(actor.cleanupTimerId);
          actor.cleanupTimerId = 0;
        }
        if (actor.laserStopTimerId !== 0) {
          window.clearTimeout(actor.laserStopTimerId);
          actor.laserStopTimerId = 0;
        }
      };

      const getPriorityBugActor = () => {
        let nextActor = null;

        activeBugActors.forEach((actor) => {
          if (!nextActor) {
            nextActor = actor;
            return;
          }

          const actorPriority = actor.state === "firing" ? 2 : actor.state === "aiming" ? 1 : 0;
          const nextPriority = nextActor.state === "firing" ? 2 : nextActor.state === "aiming" ? 1 : 0;

          if (actorPriority > nextPriority || (actorPriority === nextPriority && actor.serial > nextActor.serial)) {
            nextActor = actor;
          }
        });

        return nextActor;
      };

      const syncEyeAimOverride = () => {
        const aimActor = getPriorityBugActor();

        if (!aimActor) {
          eyeAimOverrideActive = false;
          requestMascotMotion();
          return;
        }

        const bugRect = aimActor.bugEl.getBoundingClientRect();
        const eyeOffset = getEyeOffsetForPoint(
          bugRect.left + (bugRect.width / 2),
          bugRect.top + (bugRect.height / 2),
        );
        eyeAimOverrideActive = true;
        eyeAimOverrideX = eyeOffset.x;
        eyeAimOverrideY = eyeOffset.y;
        requestMascotMotion();
      };

      const clearBugTimers = () => {
        if (bugScheduleTimerId !== 0) {
          window.clearTimeout(bugScheduleTimerId);
          bugScheduleTimerId = 0;
        }
      };

      const clearBugActors = () => {
        activeBugActors.slice().forEach((actor) => {
          clearBugActorTimers(actor);
          actor.laserEl.remove();
          actor.bugEl.remove();
        });
        activeBugActors.length = 0;
      };

      const hideBugScene = () => {
        clearBugActors();
        eyeAimOverrideActive = false;
        updateDefenseScene();
        requestMascotMotion();
      };

      const clearPendingBlinkTimers = () => {
        if (blinkFollowupTimerId !== 0) {
          window.clearTimeout(blinkFollowupTimerId);
          blinkFollowupTimerId = 0;
        }
        if (blinkResetTimerId !== 0) {
          window.clearTimeout(blinkResetTimerId);
          blinkResetTimerId = 0;
        }
      };

      const clearBlinkTimers = () => {
        if (blinkScheduleTimerId !== 0) {
          window.clearTimeout(blinkScheduleTimerId);
          blinkScheduleTimerId = 0;
        }
        clearPendingBlinkTimers();
      };

      const setBlinking = (isBlinking) => {
        eye.classList.toggle("is-blinking", isBlinking);
      };

      const triggerBlink = (shouldDoubleBlink = false) => {
        clearPendingBlinkTimers();
        setBlinking(false);
        void eye.offsetWidth;
        setBlinking(true);

        blinkResetTimerId = window.setTimeout(() => {
          setBlinking(false);
          blinkResetTimerId = 0;

          if (shouldDoubleBlink && document.visibilityState === "visible") {
            blinkFollowupTimerId = window.setTimeout(() => {
              blinkFollowupTimerId = 0;
              triggerBlink(false);
            }, 140);
          }
        }, 190);
      };

      const scheduleBlink = () => {
        if (document.visibilityState !== "visible") {
          return;
        }

        if (blinkScheduleTimerId !== 0) {
          window.clearTimeout(blinkScheduleTimerId);
        }
        const delay = 2400 + (Math.random() * 4600);
        // Blink timing is separate from pointer motion so the eye still feels alive when idle.
        blinkScheduleTimerId = window.setTimeout(() => {
          blinkScheduleTimerId = 0;
          triggerBlink(Math.random() < 0.2);
          scheduleBlink();
        }, delay);
      };

      const getEyeOffsetForPoint = (clientX, clientY) => {
        const shieldRect = shield.getBoundingClientRect();
        const eyeRect = eye.getBoundingClientRect();
        const shieldCx = shieldRect.left + (shieldRect.width / 2);
        const shieldCy = shieldRect.top + (shieldRect.height / 2);
        const eyeRange = Math.max(
          0,
          Math.min(
            eyeRect.left - shieldRect.left,
            shieldRect.right - eyeRect.right,
            eyeRect.top - shieldRect.top,
            shieldRect.bottom - eyeRect.bottom,
          ) - 0.5,
        );

        return clampToCircle(clientX - shieldCx, clientY - shieldCy, eyeRange);
      };

      const isFlowAboveFold = () => {
        const rect = flow.getBoundingClientRect();
        return rect.bottom > 0 && rect.top < (window.innerHeight * 0.95);
      };

      const getBugSpawnOrigin = () => {
        const stageRect = getBugStageRect();
        return {
          x: clamp(lastPointerClientX - stageRect.left, 0, stageRect.width),
          y: clamp(lastPointerClientY - stageRect.top, 0, stageRect.height),
        };
      };

      const getBugStageRect = () => bugStage.getBoundingClientRect();

      const positionBug = (actor, originPoint = null) => {
        const stageRect = getBugStageRect();
        const bugHalfWidth = 16;
        const bugHalfHeight = 16;

        let startX = 0;
        let startY = 0;
        let direction = 1;

        if (originPoint) {
          startX = originPoint.x;
          startY = originPoint.y;
          direction = startX < (stageRect.width / 2) ? 1 : -1;
        } else {
          startX = stageRect.width / 2;
          startY = stageRect.height * 0.16;
          direction = 1;
        }

        const travelX = (180 + (Math.random() * 140)) * direction;
        const endX = clamp(startX + travelX, bugHalfWidth, stageRect.width - bugHalfWidth);
        const endY = clamp(
          startY + ((Math.random() * 64) - 32),
          bugHalfHeight,
          stageRect.height - bugHalfHeight,
        );
        const runDuration = 860 + (Math.random() * 300);
        const deltaX = endX - startX;
        const deltaY = endY - startY;
        const zigAmplitude = 18 + (Math.random() * 28);
        const zigDirection = Math.random() < 0.5 ? -1 : 1;
        const zig1X = deltaX * (0.26 + (Math.random() * 0.1));
        const zig2X = deltaX * (0.62 + (Math.random() * 0.12));
        const zig1Y = (deltaY * 0.3) + (zigAmplitude * zigDirection);
        const zig2Y = (deltaY * 0.68) - (zigAmplitude * zigDirection * 0.9);
        const angle0 = (Math.atan2(zig1Y, zig1X) * (180 / Math.PI)) + 90;
        const angle1 = (Math.atan2(zig2Y - zig1Y, zig2X - zig1X) * (180 / Math.PI)) + 90;
        const angle2 = (Math.atan2(deltaY - zig2Y, deltaX - zig2X) * (180 / Math.PI)) + 90;

        actor.bugEl.style.setProperty("--bug-left", `${startX.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-top", `${startY.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-run-x", `${deltaX.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-run-y", `${deltaY.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-zig-1x", `${zig1X.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-zig-1y", `${zig1Y.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-zig-2x", `${zig2X.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-zig-2y", `${zig2Y.toFixed(2)}px`);
        actor.bugEl.style.setProperty("--bug-angle-0", `${angle0.toFixed(2)}deg`);
        actor.bugEl.style.setProperty("--bug-angle-1", `${angle1.toFixed(2)}deg`);
        actor.bugEl.style.setProperty("--bug-angle-2", `${angle2.toFixed(2)}deg`);
        actor.bugEl.style.setProperty("--bug-run-duration", `${runDuration.toFixed(0)}ms`);

        return runDuration;
      };

      const spawnBugAttack = (originPoint = null) => {
        if (document.visibilityState !== "visible" || !isFlowAboveFold()) {
          return false;
        }

        const actor = {
          ...createBugActorElements(),
          serial: ++bugActorSerial,
          state: "running",
          aimTimerId: 0,
          hitTimerId: 0,
          cleanupTimerId: 0,
          laserStopTimerId: 0,
        };
        activeBugActors.push(actor);
        actor.bugEl.style.setProperty("--bug-color", pickPaletteColor(bugPalette));

        const runDuration = positionBug(actor, originPoint);
        actor.bugEl.classList.add("is-active");
        updateDefenseScene();

        actor.aimTimerId = window.setTimeout(() => {
          actor.aimTimerId = 0;
          actor.state = "aiming";
          syncEyeAimOverride();
        }, runDuration - 180);

        actor.hitTimerId = window.setTimeout(() => {
          actor.hitTimerId = 0;
          const bugTransform = window.getComputedStyle(actor.bugEl).transform;
          actor.bugEl.classList.remove("is-active");
          if (bugTransform !== "none") {
            actor.bugEl.style.transform = bugTransform;
          }
          actor.state = "firing";
          actor.laserEl.classList.add("is-active");
          updateDefenseScene();
          void actor.bugEl.offsetWidth;
          actor.bugEl.classList.add("is-hit");
          syncEyeAimOverride();
        }, runDuration + 120);

        actor.laserStopTimerId = window.setTimeout(() => {
          actor.laserStopTimerId = 0;
          actor.laserEl.classList.remove("is-active");
          actor.laserEl.style.setProperty("--laser-length", "0px");
        }, runDuration + 280);

        actor.cleanupTimerId = window.setTimeout(() => {
          actor.cleanupTimerId = 0;
          clearBugActorTimers(actor);
          actor.laserEl.remove();
          actor.bugEl.remove();
          const actorIndex = activeBugActors.indexOf(actor);
          if (actorIndex !== -1) {
            activeBugActors.splice(actorIndex, 1);
          }
          syncEyeAimOverride();
          updateDefenseScene();
          scheduleBugPatrol();
        }, runDuration + 1220);

        return true;
      };

      const scheduleBugPatrol = (isInitial = false) => {
        if (document.visibilityState !== "visible" || !isFlowAboveFold()) {
          return;
        }

        if (bugScheduleTimerId !== 0) {
          window.clearTimeout(bugScheduleTimerId);
        }

        const delay = isInitial
          ? 3800 + (Math.random() * 2600)
          : 9000 + (Math.random() * 9000);

        bugScheduleTimerId = window.setTimeout(() => {
          bugScheduleTimerId = 0;
          if (!isFlowAboveFold()) {
            scheduleBugPatrol(true);
            return;
          }

          if (!spawnBugAttack(getBugSpawnOrigin())) {
            scheduleBugPatrol(true);
          }
        }, delay);
      };

      updateDefenseScene = () => {
        const stageRect = getBugStageRect();
        const pupilRect = pupil.getBoundingClientRect();
        const startX = (pupilRect.left - stageRect.left) + (pupilRect.width / 2);
        const startY = (pupilRect.top - stageRect.top) + (pupilRect.height / 2);

        activeBugActors.forEach((actor) => {
          const bugRect = actor.bugEl.getBoundingClientRect();
          const endX = (bugRect.left - stageRect.left) + (bugRect.width / 2);
          const endY = (bugRect.top - stageRect.top) + (bugRect.height / 2);
          const dx = endX - startX;
          const dy = endY - startY;
          const length = Math.hypot(dx, dy);
          const angle = Math.atan2(dy, dx) * (180 / Math.PI);

          actor.laserEl.style.setProperty("--laser-x", `${startX.toFixed(2)}px`);
          actor.laserEl.style.setProperty("--laser-y", `${startY.toFixed(2)}px`);
          actor.laserEl.style.setProperty("--laser-length", actor.laserEl.classList.contains("is-active") ? `${length.toFixed(2)}px` : "0px");
          actor.laserEl.style.setProperty("--laser-angle", `${angle.toFixed(2)}deg`);
        });
      };

      const mapPointerToMascot = (clientX, clientY) => {
        const nodeRect = warden.getBoundingClientRect();
        const shieldRect = shield.getBoundingClientRect();
        const nodeCx = nodeRect.left + (nodeRect.width / 2);
        const nodeCy = nodeRect.top + (nodeRect.height / 2);
        const nodeNormalizedX = (clientX - nodeCx) / Math.max(window.innerWidth * 0.5, 1);
        const nodeNormalizedY = (clientY - nodeCy) / Math.max(window.innerHeight * 0.5, 1);
        const panelShimmerReachX = motionEnabled ? 0.68 : 0.5;
        const panelShimmerReachY = motionEnabled ? 0.58 : 0.5;
        const normalizedX = (clientX - nodeCx) / Math.max(window.innerWidth * panelShimmerReachX, 1);
        const normalizedY = (clientY - nodeCy) / Math.max(window.innerHeight * panelShimmerReachY, 1);

        const dampAxis = (value, gain) => Math.tanh(value * gain) / Math.tanh(gain);
        const nodeShimmerXRaw = dampAxis(nodeNormalizedX, 2.15);
        const nodeShimmerYRaw = dampAxis(nodeNormalizedY, 1.45);
        const shimmerXRaw = dampAxis(normalizedX, 2.15);
        const shimmerYRaw = dampAxis(normalizedY, 1.45);
        const nodeShimmerMagnitude = Math.hypot(nodeShimmerXRaw, nodeShimmerYRaw);
        const shimmerMagnitude = Math.hypot(shimmerXRaw, shimmerYRaw);
        const nodeTargetDir = nodeShimmerMagnitude > 0.0001
          ? { x: nodeShimmerXRaw / nodeShimmerMagnitude, y: nodeShimmerYRaw / nodeShimmerMagnitude }
          : { x: shimmerDirX, y: shimmerDirY };
        const targetDir = shimmerMagnitude > 0.0001
          ? { x: shimmerXRaw / shimmerMagnitude, y: shimmerYRaw / shimmerMagnitude }
          : { x: shimmerDirX, y: shimmerDirY };
        // Cursor influence is intentionally damped near the Warden center.
        const centerDistance = Math.min(1, Math.hypot(normalizedX, normalizedY) / Math.SQRT2);
        const directionalInfluence = 0.14 + (Math.pow(centerDistance, 1.45) * 0.86);
        const nodeCenterDistance = Math.min(1, Math.hypot(nodeNormalizedX, nodeNormalizedY) / Math.SQRT2);
        const nodeDirectionalInfluence = 0.14 + (Math.pow(nodeCenterDistance, 1.45) * 0.86);
        const nodeBlendedDir = {
          x: (shimmerDirX * (1 - nodeDirectionalInfluence)) + (nodeTargetDir.x * nodeDirectionalInfluence),
          y: (shimmerDirY * (1 - nodeDirectionalInfluence)) + (nodeTargetDir.y * nodeDirectionalInfluence),
        };
        const blendedDir = {
          x: (shimmerDirX * (1 - directionalInfluence)) + (targetDir.x * directionalInfluence),
          y: (shimmerDirY * (1 - directionalInfluence)) + (targetDir.y * directionalInfluence),
        };
        const nodeBlendedMagnitude = Math.max(Math.hypot(nodeBlendedDir.x, nodeBlendedDir.y), 0.0001);
        const blendedMagnitude = Math.max(Math.hypot(blendedDir.x, blendedDir.y), 0.0001);
        const nodeShimmerDirX = nodeBlendedDir.x / nodeBlendedMagnitude;
        const nodeShimmerDirY = nodeBlendedDir.y / nodeBlendedMagnitude;
        shimmerDirX = blendedDir.x / blendedMagnitude;
        shimmerDirY = blendedDir.y / blendedMagnitude;
        const rawShimmerTravel = Math.min(1, shimmerMagnitude);
        const panelShimmerTravel = motionEnabled
          ? lerp(rawShimmerTravel, rawShimmerTravel * rawShimmerTravel, 0.38)
          : 1;
        const nodeShimmer = projectToCircleBorder(nodeShimmerDirX, nodeShimmerDirY);
        const panelShimmer = {
          x: shimmerDirX * panelShimmerTravel,
          y: shimmerDirY * panelShimmerTravel,
        };
        const nodeMotionScale = motionEnabled ? 0.11 : 0.22;
        const nodeRange = Math.max(0, Math.min(nodeRect.width, nodeRect.height) * nodeMotionScale);
        const nodeOffset = clampToCircle(clientX - nodeCx, clientY - nodeCy, nodeRange);
        nodeTargetX = nodeOffset.x;
        nodeTargetY = nodeOffset.y;
        nodeTargetBorderX = 50 + (nodeShimmer.x * 46);
        nodeTargetBorderY = 50 + (nodeShimmer.y * 46);
        nodeTargetHighlightX = 50 + (nodeShimmer.x * 38);
        nodeTargetHighlightY = 50 + (nodeShimmer.y * 38);

        const shieldRange = Math.max(
          0,
          Math.min(
            shieldRect.left - nodeRect.left,
            nodeRect.right - shieldRect.right,
            shieldRect.top - nodeRect.top,
            nodeRect.bottom - shieldRect.bottom,
          ) - 1,
        );
        const shieldOffset = clampToCircle(clientX - nodeCx, clientY - nodeCy, shieldRange);
        shieldTargetX = shieldOffset.x;
        shieldTargetY = shieldOffset.y;
        const eyeOffset = getEyeOffsetForPoint(clientX, clientY);
        eyeTargetX = eyeOffset.x;
        eyeTargetY = eyeOffset.y;

        skillMotionStates.forEach((state) => {
          if (getComputedStyle(state.el).display === "none") {
            state.targetX = 0;
            state.targetY = 0;
            state.targetBorderX = 50;
            state.targetBorderY = 50;
            return;
          }

          state.targetX = 0;
          state.targetY = 0;
          state.targetBorderX = 50 + (panelShimmer.x * 48);
          state.targetBorderY = 50 + (panelShimmer.y * 42);
        });
        panelMotionStates.forEach((state) => {
          if (getComputedStyle(state.el).display === "none") {
            state.targetBorderX = 50;
            state.targetBorderY = 50;
            return;
          }

          state.targetBorderX = 50 + (panelShimmer.x * 48);
          state.targetBorderY = 50 + (panelShimmer.y * 42);
        });

        requestMascotMotion();
      };

      const resetMascotTargets = () => {
        nodeTargetX = 0;
        nodeTargetY = 0;
        nodeTargetBorderX = 50;
        nodeTargetBorderY = 50;
        nodeTargetHighlightX = 50;
        nodeTargetHighlightY = 50;
        shieldTargetX = 0;
        shieldTargetY = 0;
        eyeTargetX = 0;
        eyeTargetY = 0;
        skillMotionStates.forEach((state) => {
          state.targetX = 0;
          state.targetY = 0;
          state.targetBorderX = 50;
          state.targetBorderY = 50;
        });
        panelMotionStates.forEach((state) => {
          state.targetBorderX = 50;
          state.targetBorderY = 50;
        });
        requestMascotMotion();
      };

      const onPointerMove = (event) => {
        lastPointerClientX = event.clientX;
        lastPointerClientY = event.clientY;
        mapPointerToMascot(event.clientX, event.clientY);
      };
      const onVisibilityChange = () => {
        if (document.visibilityState !== "visible") {
          clearBlinkTimers();
          clearBugTimers();
          hideBugScene();
          setBlinking(false);
          resetMascotTargets();
          return;
        }
        scheduleBlink();
        scheduleBugPatrol(true);
      };
      const onWindowScroll = () => {
        if (!isFlowAboveFold()) {
          clearBugTimers();
          hideBugScene();
          return;
        }

        updateDefenseScene();

        if (document.visibilityState === "visible" && bugScheduleTimerId === 0) {
          scheduleBugPatrol(true);
        }
      };
      const onDocumentClick = (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }

        const interactive = target.closest(
          "a, button, input, select, textarea, summary, label, details, [role='button'], [role='link'], [contenteditable='true'], [tabindex]:not([tabindex='-1'])",
        );
        if (interactive) {
          return;
        }

        const stageRect = getBugStageRect();
        const withinStage =
          event.clientX >= stageRect.left
          && event.clientX <= stageRect.right
          && event.clientY >= stageRect.top
          && event.clientY <= stageRect.bottom;
        if (!withinStage || !isFlowAboveFold()) {
          return;
        }

        lastPointerClientX = event.clientX;
        lastPointerClientY = event.clientY;
        if (spawnBugAttack({ x: event.clientX - stageRect.left, y: event.clientY - stageRect.top })) {
          scheduleBugPatrol();
        }
      };
      let activeTouchId = null;
      const onWardenTouchStart = (event) => {
        const touch = event.changedTouches[0];
        if (!touch) return;
        activeTouchId = touch.identifier;
        lastPointerClientX = touch.clientX;
        lastPointerClientY = touch.clientY;
        mapPointerToMascot(touch.clientX, touch.clientY);
      };
      const onWardenTouchMove = (event) => {
        if (activeTouchId === null) return;
        const touch = Array.from(event.touches).find((item) => item.identifier === activeTouchId);
        if (!touch) return;
        event.preventDefault();
        lastPointerClientX = touch.clientX;
        lastPointerClientY = touch.clientY;
        mapPointerToMascot(touch.clientX, touch.clientY);
      };
      const onWardenTouchEnd = (event) => {
        if (activeTouchId === null) return;
        const ended = Array.from(event.changedTouches).some((item) => item.identifier === activeTouchId);
        if (!ended) return;
        activeTouchId = null;
        resetMascotTargets();
      };

      document.addEventListener("visibilitychange", onVisibilityChange);
      document.addEventListener("click", onDocumentClick);
      window.addEventListener("scroll", onWindowScroll, { passive: true });

      if (motionEnabled) {
        window.addEventListener("pointermove", onPointerMove, { passive: true });
        window.addEventListener("blur", resetMascotTargets);
        document.addEventListener("mouseleave", resetMascotTargets);
      } else if (touchSwipeEnabled) {
        warden.addEventListener("touchstart", onWardenTouchStart, { passive: true });
        warden.addEventListener("touchmove", onWardenTouchMove, { passive: false });
        warden.addEventListener("touchend", onWardenTouchEnd);
        warden.addEventListener("touchcancel", onWardenTouchEnd);
      } else {
        applyMascotMotion();
      }

      const pickPaletteColor = (palette) => palette[Math.floor(Math.random() * palette.length)];

      const applyTrailColor = (trail, isOutputConnector, forceRandomize = false) => {
        const role = isOutputConnector ? "output" : "skill";
        const previousRole = trail.dataset.connectorRole;
        const palette = isOutputConnector ? outputTrailPalette : skillTrailPalette;

        trail.dataset.connectorRole = role;
        if (!forceRandomize && previousRole === role && trail.style.getPropertyValue("--trail-color")) {
          return;
        }

        const color = pickPaletteColor(palette);
        trail.style.setProperty("--trail-color", color);
      };

      const setTrailColor = (index, isOutputConnector = false) => {
        const trail = trails.find((item) => item.dataset.trail === String(index));
        if (!trail) return;
        applyTrailColor(trail, isOutputConnector);
      };

      trails.forEach((trail) => {
        const trailIndex = trail.dataset.trail;
        if (trailIndex == null) return;
        const index = Number(trailIndex);
        setTrailColor(index);
      });

      const trailHandlers = trails.map((trail) => {
        const onIteration = (event) => {
          if (event.animationName !== "hero-flow-trail-shift") {
            return;
          }
          applyTrailColor(trail, trail.dataset.connectorRole === "output", true);
        };
        trail.addEventListener("animationiteration", onIteration);
        return { trail, onIteration };
      });

      update = () => {
        const rootRect = flow.getBoundingClientRect();
        const width = Math.max(1, rootRect.width);
        const height = Math.max(1, rootRect.height);
        const wardenRect = warden.getBoundingClientRect();
        const maskCenterX = (wardenRect.left - rootRect.left) + (wardenRect.width / 2) + (nodeX * 3);
        const maskCenterY = (wardenRect.top - rootRect.top) + (wardenRect.height / 2) + (nodeY * 3);
        flow.style.setProperty("--hero-flow-mask-radius", `${height / 2}px`);
        flow.style.setProperty("--hero-flow-mask-center-x", `${maskCenterX}px`);
        flow.style.setProperty("--hero-flow-mask-center-y", `${maskCenterY}px`);
        svg.setAttribute("viewBox", `0 0 ${width} ${height}`);

        const mobile = window.matchMedia("(max-width: 860px)").matches;
        const activeSkills = skills.filter((skillEl) => getComputedStyle(skillEl).display !== "none");
        const connectors = [];
        let outputConnectorCount = 0;

        if (mobile) {
          const wardenCenter = heroFlowPoint(warden, "top", rootRect);
          const leftSkills = activeSkills
            .filter((skillEl) => {
              const rect = skillEl.getBoundingClientRect();
              const centerX = rect.left - rootRect.left + (rect.width / 2);
              return centerX <= wardenCenter.x;
            });
          const rightSkills = activeSkills
            .filter((skillEl) => {
              const rect = skillEl.getBoundingClientRect();
              const centerX = rect.left - rootRect.left + (rect.width / 2);
              return centerX > wardenCenter.x;
            });

          const connectorRatio = (index, total) => {
            if (total <= 1) {
              return 0.5;
            }
            return index / (total - 1);
          };
          const wardenBottomCli = heroFlowCirclePoint(warden, rootRect, 84);
          const wardenBottomPr = heroFlowCirclePoint(warden, rootRect, 96);
          const cliVisible = getComputedStyle(cli).display !== "none";
          const prVisible = getComputedStyle(pr).display !== "none";
          const leftConnectors = leftSkills.map((skillEl, index) => {
            const ratio = connectorRatio(index, leftSkills.length);
            const angle = 198 - (ratio * 36);
            const target = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "left", rootRect), target);
          });
          const rightConnectors = rightSkills.map((skillEl, index) => {
            const ratio = connectorRatio(index, rightSkills.length);
            const angle = 342 + (ratio * 36);
            const target = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "right", rootRect), target);
          });
          connectors.push(...leftConnectors);
          connectors.push(...rightConnectors);
          if (cliVisible) {
            const cliTop = heroFlowPoint(cli, "top", rootRect);
            connectors.push(
              heroFlowVertical(
                wardenBottomCli,
                { x: wardenBottomCli.x, y: cliTop.y }
              )
            );
            outputConnectorCount += 1;
          }
          if (prVisible) {
            const prTop = heroFlowPoint(pr, "top", rootRect);
            connectors.push(
              heroFlowVertical(
                wardenBottomPr,
                { x: wardenBottomPr.x, y: prTop.y }
              )
            );
            outputConnectorCount += 1;
          }
        } else {
          const skillCount = Math.max(1, activeSkills.length - 1);
          const skillConnectors = activeSkills.map((skillEl, index) => {
            const ratio = skillCount === 0 ? 0.5 : (index / skillCount);
            const angle = 228 - (ratio * 96);
            const wardenLeftSlot = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "right", rootRect), wardenLeftSlot);
          });
          const wardenRightCli = heroFlowCirclePoint(warden, rootRect, 340);
          const wardenRightPr = heroFlowCirclePoint(warden, rootRect, 20);
          connectors.push(...skillConnectors);
          connectors.push(heroFlowCurve(wardenRightCli, heroFlowPoint(cli, "left", rootRect)));
          connectors.push(heroFlowCurve(wardenRightPr, heroFlowPoint(pr, "left", rootRect)));
          outputConnectorCount = 2;
        }

        const outputStartIndex = Math.max(0, connectors.length - outputConnectorCount);
        for (let i = 0; i < lines.length; i += 1) {
          const d = connectors[i] || "";
          const isOutputConnector = d !== "" && i >= outputStartIndex && i < (outputStartIndex + outputConnectorCount);
          if (lines[i]) lines[i].setAttribute("d", d);
          flow.querySelectorAll(`[data-trail='${i}']`).forEach((trail) => {
            trail.setAttribute("d", d);
            trail.style.setProperty("--trail-duration", isOutputConnector ? "1.5s" : "15s");
            applyTrailColor(trail, isOutputConnector);
          });
          if (maskLines[i]) {
            maskLines[i].setAttribute("d", d);
          }
        }
      };

      const ro = new ResizeObserver(update);
      ro.observe(flow);
      skills.forEach((el) => ro.observe(el));
      ro.observe(warden);
      ro.observe(cli);
      ro.observe(pr);

      window.addEventListener("resize", update);
      update();
      scheduleBlink();
      scheduleBugPatrol(true);

      flow.__heroFlowCleanup = () => {
        ro.disconnect();
        window.removeEventListener("resize", update);
        clearBlinkTimers();
        clearBugTimers();
        hideBugScene();
        if (bugStageHome) {
          if (bugStageHomeNextSibling && bugStageHomeNextSibling.parentNode === bugStageHome) {
            bugStageHome.insertBefore(bugStage, bugStageHomeNextSibling);
          } else {
            bugStageHome.appendChild(bugStage);
          }
        }
        setBlinking(false);
        document.removeEventListener("visibilitychange", onVisibilityChange);
        document.removeEventListener("click", onDocumentClick);
        window.removeEventListener("scroll", onWindowScroll);
        if (motionEnabled) {
          window.removeEventListener("pointermove", onPointerMove);
          window.removeEventListener("blur", resetMascotTargets);
          document.removeEventListener("mouseleave", resetMascotTargets);
        } else if (touchSwipeEnabled) {
          warden.removeEventListener("touchstart", onWardenTouchStart);
          warden.removeEventListener("touchmove", onWardenTouchMove);
          warden.removeEventListener("touchend", onWardenTouchEnd);
          warden.removeEventListener("touchcancel", onWardenTouchEnd);
        }
        if (rafId !== 0) {
          window.cancelAnimationFrame(rafId);
          rafId = 0;
        }
        trailHandlers.forEach(({ trail, onIteration }) => {
          if (trail && onIteration) {
            trail.removeEventListener("animationiteration", onIteration);
          }
        });
      };
    });
  }

  setupHeroFlows();
  document.addEventListener("astro:page-load", setupHeroFlows);
</script>

