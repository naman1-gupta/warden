---
const skills = [
  "security-scanning",
  "api-design-review",
  "architecture-review",
  "dependency-review",
  "test-coverage",
  "auth-hardening",
  "performance-guardrails",
  "error-handling",
];
const desktopSkillLayout = [
  { side: "right", inset: "0rem" },
  { side: "left", inset: "0rem" },
  { side: "right", inset: "1.1rem" },
  { side: "left", inset: "0.55rem" },
  { side: "right", inset: "2rem" },
  { side: "left", inset: "1.45rem" },
  { side: "left", inset: "2.25rem" },
  { side: "right", inset: "0.45rem" },
];
const connectorCount = skills.length + 2;
---

<section class="hero-flow" aria-label="Warden trigger flow">
  <div class="hero-flow-bg" aria-hidden="true"></div>
  <svg class="hero-flow-lines" preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <mask id="hero-flow-dash-mask" maskUnits="userSpaceOnUse" maskContentUnits="userSpaceOnUse">
        {Array.from({ length: connectorCount }).map((_, idx) => (
          <path class="hero-flow-mask-path" data-mask-line={idx}></path>
        ))}
      </mask>
    </defs>
    {Array.from({ length: connectorCount }).map((_, idx) => (
      <path class="hero-flow-line" data-line={idx}></path>
    ))}
    <g class="hero-flow-trails" mask="url(#hero-flow-dash-mask)">
      {Array.from({ length: connectorCount }).map((_, idx) => (
        <path
          class="hero-flow-trail"
          data-trail={idx}
          style={`--trail-delay:${idx * 0.18}s`}
        ></path>
      ))}
    </g>
  </svg>

  <div class="hero-flow-grid">
    <div class="hero-flow-column hero-flow-column-skills">
      <span class="hero-flow-label">Skills</span>
      <div class="hero-flow-skills-clip">
        <div class="hero-flow-skills-list">
          {skills.map((skill, index) => (
            <div
              class="hero-skill-card"
              data-anchor={`skill-${index}`}
              data-side={desktopSkillLayout[index % desktopSkillLayout.length].side}
              style={`--skill-inset:${desktopSkillLayout[index % desktopSkillLayout.length].inset}`}
            >
              <span class="hero-skill-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M7 3.75h6.5L18.25 8.5V20a1.25 1.25 0 0 1-1.25 1.25H7A1.25 1.25 0 0 1 5.75 20V5A1.25 1.25 0 0 1 7 3.75Z" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M13.5 3.75V8.5h4.75" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M8.5 12.25h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                  <path d="M8.5 15.75h4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
              </span>
              <code>{skill}</code>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="hero-flow-column hero-flow-column-center">
      <div class="warden-node" data-anchor="warden" aria-label="Warden">
        <span class="warden-shield">
          <span class="warden-eye">
            <span class="warden-iris"></span>
          </span>
        </span>
      </div>
    </div>

    <div class="hero-flow-column hero-flow-column-output">
      <span class="hero-flow-label">Run before you push</span>
      <div class="hero-cli" data-anchor="cli">
        <div class="hero-cli-header" aria-hidden="true">
          <span class="hero-cli-dot dot-red"></span>
          <span class="hero-cli-dot dot-yellow"></span>
          <span class="hero-cli-dot dot-green"></span>
        </div>
        <div class="hero-cli-body">
          <span class="cli-dim">$</span> warden
        </div>
      </div>

      <span class="hero-flow-label hero-flow-label-pr">Every pull request</span>
      <div class="hero-pr-clip">
        <div class="pr-mock" data-anchor="pr">
          <div class="pr-mock-header">
            <div class="pr-mock-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="12" fill="#000"></circle>
                <g transform="translate(12, 12) scale(0.65) translate(-12, -12)">
                  <path d="M14.2666 4.9061C15.1564 4.09409 16.5921 4.60917 16.7627 5.80162L18.1123 15.2519C18.9476 14.5758 19.6675 14.156 20.2706 13.9423C20.9583 13.6988 21.61 13.6893 22.0606 14.0459C22.5331 14.4202 22.576 15.0232 22.4131 15.5224C22.2471 16.0308 21.8525 16.5326 21.2774 16.916C20.2382 17.6088 19.1848 18.1368 17.7432 18.4863C16.3131 18.833 14.518 19 12 19C9.48202 19 7.68685 18.833 6.25679 18.4863C4.81521 18.1368 3.76183 17.6088 2.72259 16.916C2.14753 16.5326 1.75289 16.0308 1.58684 15.5224C1.42401 15.0233 1.46701 14.4202 1.93938 14.0459C2.38997 13.6893 3.04168 13.6988 3.72943 13.9423C4.33238 14.1559 5.05163 14.5761 5.88667 15.2519L7.23727 5.80162C7.40784 4.60919 8.84362 4.09419 9.73338 4.9061L11.6631 6.66686C11.854 6.84121 12.146 6.84121 12.3369 6.66686L14.2666 4.9061Z" fill="white"></path>
                  <path d="M12 8L13.1226 11.1094H16.7553L13.8164 13.0312L14.9389 16.1406L12 14.2188L9.06107 16.1406L10.1836 13.0312L7.24472 11.1094H10.8774L12 8Z" fill="#000"></path>
                </g>
              </svg>
            </div>
            <div class="pr-mock-meta">
              <span class="pr-mock-name">warden</span>
              <span class="pr-mock-badge">bot</span>
              <span class="pr-mock-time">commented now</span>
            </div>
          </div>
          <div class="pr-mock-body">
            <div class="pr-mock-finding">
              <span class="pr-mock-severity severity-high"></span>
              <span class="pr-mock-title">SQL injection via unsanitized input</span>
            </div>
            <p class="pr-mock-desc">User input is interpolated directly into a SQL query. Use parameterized queries to prevent SQL injection attacks.</p>
            <p class="pr-mock-suggestion-label"><strong>Suggested fix:</strong> Use parameterized query</p>
            <div class="pr-mock-suggestion">
              <div class="pr-mock-suggestion-header">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8.75 1.75V5H12a.75.75 0 010 1.5H8.75v3.25a.75.75 0 01-1.5 0V6.5H4a.75.75 0 010-1.5h3.25V1.75a.75.75 0 011.5 0zM4 13a.75.75 0 000 1.5h8a.75.75 0 000-1.5H4z"/>
                </svg>
                <span>Suggested change</span>
              </div>
              <div class="pr-mock-suggestion-diff">
                <div class="pr-mock-diff-line diff-old">
                  <span class="diff-marker">-</span>
                  <span class="diff-content">db.query(`SELECT * FROM users WHERE id = $&#123;id&#125;`)</span>
                </div>
                <div class="pr-mock-diff-line diff-new">
                  <span class="diff-marker">+</span>
                  <span class="diff-content">db.query("SELECT * FROM users WHERE id = $1", [id])</span>
                </div>
              </div>
              <div class="pr-mock-suggestion-actions">
                <button class="pr-mock-commit-btn">Commit suggestion</button>
              </div>
            </div>
          </div>
          <div class="pr-mock-footer">
            <a href="#" class="pr-mock-link">View all 3 findings</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function heroFlowPoint(el, side, rootRect, offset = 0) {
    const rect = el.getBoundingClientRect();
    if (side === "top") {
      return {
        x: rect.left - rootRect.left + rect.width * (0.5 + offset),
        y: rect.top - rootRect.top,
      };
    }
    if (side === "bottom") {
      return {
        x: rect.left - rootRect.left + rect.width * (0.5 + offset),
        y: rect.bottom - rootRect.top,
      };
    }
    if (side === "left") {
      return {
        x: rect.left - rootRect.left,
        y: rect.top - rootRect.top + rect.height * (0.5 + offset),
      };
    }
    return {
      x: rect.right - rootRect.left,
      y: rect.top - rootRect.top + rect.height * (0.5 + offset),
    };
  }

  function heroFlowCirclePoint(el, rootRect, angleDeg) {
    const rect = el.getBoundingClientRect();
    const cx = rect.left - rootRect.left + rect.width / 2;
    const cy = rect.top - rootRect.top + rect.height / 2;
    const radius = (Math.min(rect.width, rect.height) / 2) - 0.5;
    const angle = (angleDeg * Math.PI) / 180;
    return {
      x: cx + radius * Math.cos(angle),
      y: cy + radius * Math.sin(angle),
    };
  }

  function heroFlowCurve(a, b) {
    const dx = Math.abs(b.x - a.x);
    const ctrl = Math.max(26, dx * 0.42);
    const dir = b.x >= a.x ? 1 : -1;
    const c1x = a.x + (dir * ctrl);
    const c2x = b.x - (dir * ctrl);
    return `M ${a.x} ${a.y} C ${c1x} ${a.y} ${c2x} ${b.y} ${b.x} ${b.y}`;
  }

  function heroFlowFan(a, b) {
    const midY = a.y + (b.y - a.y) * 0.58;
    return `M ${a.x} ${a.y} C ${a.x} ${midY} ${b.x} ${midY} ${b.x} ${b.y}`;
  }

  function heroFlowVertical(a, b) {
    const midY = (a.y + b.y) / 2;
    return `M ${a.x} ${a.y} C ${a.x} ${midY} ${b.x} ${midY} ${b.x} ${b.y}`;
  }

  function setupHeroFlows() {
    document.querySelectorAll(".hero-flow").forEach((flow) => {
      if (flow.__heroFlowCleanup) {
        flow.__heroFlowCleanup();
      }

      const svg = flow.querySelector(".hero-flow-lines");
      const lines = Array.from(flow.querySelectorAll("[data-line]"));
      const skills = Array.from(flow.querySelectorAll("[data-anchor^='skill-']"));
      const warden = flow.querySelector("[data-anchor='warden']");
      const shield = flow.querySelector(".warden-shield");
      const eye = flow.querySelector(".warden-eye");
      const cli = flow.querySelector("[data-anchor='cli']");
      const pr = flow.querySelector("[data-anchor='pr']");
      const trails = Array.from(flow.querySelectorAll("[data-trail]"));
      const maskLines = Array.from(flow.querySelectorAll("[data-mask-line]"));
      const palette = ["#22d3ee", "#facc15", "#f87171", "#4ade80"];

      if (!svg || skills.length < 3 || !warden || !shield || !eye || !cli || !pr) {
        return;
      }

      const motionEnabled = window.matchMedia("(pointer: fine)").matches;
      const clampToCircle = (dx, dy, maxRadius) => {
        const distance = Math.hypot(dx, dy);
        if (distance <= maxRadius || distance === 0) {
          return { x: dx, y: dy };
        }
        const ratio = maxRadius / distance;
        return { x: dx * ratio, y: dy * ratio };
      };

      let update = () => {};
      let rafId = 0;
      let nodeX = 0;
      let nodeY = 0;
      let nodeTargetX = 0;
      let nodeTargetY = 0;
      let shieldX = 0;
      let shieldY = 0;
      let shieldTargetX = 0;
      let shieldTargetY = 0;
      let eyeX = 0;
      let eyeY = 0;
      let eyeTargetX = 0;
      let eyeTargetY = 0;

      const applyMascotMotion = () => {
        warden.style.setProperty("--node-x", `${nodeX.toFixed(2)}px`);
        warden.style.setProperty("--node-y", `${nodeY.toFixed(2)}px`);
        shield.style.setProperty("--shield-x", `${shieldX.toFixed(2)}px`);
        shield.style.setProperty("--shield-y", `${shieldY.toFixed(2)}px`);
        eye.style.setProperty("--eye-x", `${eyeX.toFixed(2)}px`);
        eye.style.setProperty("--eye-y", `${eyeY.toFixed(2)}px`);
        update();
      };

      const animateMascotMotion = () => {
        const ease = 0.16;
        nodeX += (nodeTargetX - nodeX) * ease;
        nodeY += (nodeTargetY - nodeY) * ease;
        shieldX += (shieldTargetX - shieldX) * ease;
        shieldY += (shieldTargetY - shieldY) * ease;
        eyeX += (eyeTargetX - eyeX) * ease;
        eyeY += (eyeTargetY - eyeY) * ease;
        applyMascotMotion();

        const settled =
          Math.abs(nodeTargetX - nodeX) < 0.06
          && Math.abs(nodeTargetY - nodeY) < 0.06
          Math.abs(shieldTargetX - shieldX) < 0.06
          && Math.abs(shieldTargetY - shieldY) < 0.06
          && Math.abs(eyeTargetX - eyeX) < 0.06
          && Math.abs(eyeTargetY - eyeY) < 0.06;

        if (settled) {
          nodeX = nodeTargetX;
          nodeY = nodeTargetY;
          shieldX = shieldTargetX;
          shieldY = shieldTargetY;
          eyeX = eyeTargetX;
          eyeY = eyeTargetY;
          applyMascotMotion();
          rafId = 0;
          return;
        }

        rafId = window.requestAnimationFrame(animateMascotMotion);
      };

      const requestMascotMotion = () => {
        if (rafId !== 0) return;
        rafId = window.requestAnimationFrame(animateMascotMotion);
      };

      const mapPointerToMascot = (clientX, clientY) => {
        const viewportWidth = Math.max(window.innerWidth, 1);
        const viewportHeight = Math.max(window.innerHeight, 1);
        const nodeRect = warden.getBoundingClientRect();
        const shieldRect = shield.getBoundingClientRect();
        const eyeRect = eye.getBoundingClientRect();

        const viewportX = ((clientX / viewportWidth) * 2) - 1;
        const viewportY = ((clientY / viewportHeight) * 2) - 1;
        const nodeRange = Math.max(0, Math.min(nodeRect.width, nodeRect.height) * 0.2);
        const nodeOffset = clampToCircle(viewportX * nodeRange, viewportY * nodeRange, nodeRange);
        nodeTargetX = nodeOffset.x;
        nodeTargetY = nodeOffset.y;

        const nodeCx = nodeRect.left + (nodeRect.width / 2);
        const nodeCy = nodeRect.top + (nodeRect.height / 2);
        const shieldRange = Math.max(
          0,
          Math.min(
            shieldRect.left - nodeRect.left,
            nodeRect.right - shieldRect.right,
            shieldRect.top - nodeRect.top,
            nodeRect.bottom - shieldRect.bottom,
          ) - 1,
        );
        const shieldOffset = clampToCircle(clientX - nodeCx, clientY - nodeCy, shieldRange);
        shieldTargetX = shieldOffset.x;
        shieldTargetY = shieldOffset.y;

        const shieldCx = shieldRect.left + (shieldRect.width / 2);
        const shieldCy = shieldRect.top + (shieldRect.height / 2);
        const eyeRange = Math.max(
          0,
          Math.min(
            eyeRect.left - shieldRect.left,
            shieldRect.right - eyeRect.right,
            eyeRect.top - shieldRect.top,
            shieldRect.bottom - eyeRect.bottom,
          ) - 0.5,
        );
        const eyeOffset = clampToCircle(clientX - shieldCx, clientY - shieldCy, eyeRange);
        eyeTargetX = eyeOffset.x;
        eyeTargetY = eyeOffset.y;

        requestMascotMotion();
      };

      const resetMascotTargets = () => {
        nodeTargetX = 0;
        nodeTargetY = 0;
        shieldTargetX = 0;
        shieldTargetY = 0;
        eyeTargetX = 0;
        eyeTargetY = 0;
        requestMascotMotion();
      };

      const onPointerMove = (event) => {
        mapPointerToMascot(event.clientX, event.clientY);
      };
      const onVisibilityChange = () => {
        if (document.visibilityState !== "visible") {
          resetMascotTargets();
        }
      };

      if (motionEnabled) {
        window.addEventListener("pointermove", onPointerMove, { passive: true });
        window.addEventListener("blur", resetMascotTargets);
        document.addEventListener("mouseleave", resetMascotTargets);
        document.addEventListener("visibilitychange", onVisibilityChange);
      } else {
        applyMascotMotion();
      }

      const setTrailColor = (index) => {
        const trail = trails.find((item) => item.dataset.trail === String(index));
        if (!trail) return;
        const color = palette[Math.floor(Math.random() * palette.length)];
        trail.style.stroke = color;
      };

      trails.forEach((trail) => {
        const trailIndex = trail.dataset.trail;
        if (trailIndex == null) return;
        const index = Number(trailIndex);
        setTrailColor(index);
      });

      const trailHandlers = trails.map((trail) => {
        const onIteration = () => {
          const trailIndex = trail.dataset.trail;
          if (trailIndex == null) return;
          setTrailColor(Number(trailIndex));
        };
        trail.addEventListener("animationiteration", onIteration);
        return { trail, onIteration };
      });

      update = () => {
        const rootRect = flow.getBoundingClientRect();
        const width = Math.max(1, rootRect.width);
        const height = Math.max(1, rootRect.height);
        flow.style.setProperty("--hero-flow-mask-radius", `${height / 2}px`);
        svg.setAttribute("viewBox", `0 0 ${width} ${height}`);

        const mobile = window.matchMedia("(max-width: 860px)").matches;
        const activeSkills = skills.filter((skillEl) => getComputedStyle(skillEl).display !== "none");
        const connectors = [];

        if (mobile) {
          const wardenCenter = heroFlowPoint(warden, "top", rootRect);
          const leftSkills = activeSkills
            .filter((skillEl) => {
              const rect = skillEl.getBoundingClientRect();
              const centerX = rect.left - rootRect.left + (rect.width / 2);
              return centerX <= wardenCenter.x;
            });
          const rightSkills = activeSkills
            .filter((skillEl) => {
              const rect = skillEl.getBoundingClientRect();
              const centerX = rect.left - rootRect.left + (rect.width / 2);
              return centerX > wardenCenter.x;
            });

          const leftCount = Math.max(1, leftSkills.length - 1);
          const rightCount = Math.max(1, rightSkills.length - 1);
          const wardenBottomCli = heroFlowCirclePoint(warden, rootRect, 84);
          const wardenBottomPr = heroFlowCirclePoint(warden, rootRect, 96);
          const cliTop = heroFlowPoint(cli, "top", rootRect);
          const prTop = heroFlowPoint(pr, "top", rootRect);
          const leftConnectors = leftSkills.map((skillEl, index) => {
            const ratio = leftCount === 0 ? 0.5 : (index / leftCount);
            const angle = 252 - (ratio * 44);
            const target = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "right", rootRect), target);
          });
          const rightConnectors = rightSkills.map((skillEl, index) => {
            const ratio = rightCount === 0 ? 0.5 : (index / rightCount);
            const angle = 288 + (ratio * 44);
            const target = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "left", rootRect), target);
          });
          connectors.push(...leftConnectors);
          connectors.push(...rightConnectors);
          connectors.push(
            heroFlowVertical(
              wardenBottomCli,
              { x: wardenBottomCli.x, y: cliTop.y }
            )
          );
          connectors.push(
            heroFlowVertical(
              wardenBottomPr,
              { x: wardenBottomPr.x, y: prTop.y }
            )
          );
        } else {
          const skillCount = Math.max(1, activeSkills.length - 1);
          const skillConnectors = activeSkills.map((skillEl, index) => {
            const ratio = skillCount === 0 ? 0.5 : (index / skillCount);
            const angle = 228 - (ratio * 96);
            const wardenLeftSlot = heroFlowCirclePoint(warden, rootRect, angle);
            return heroFlowCurve(heroFlowPoint(skillEl, "right", rootRect), wardenLeftSlot);
          });
          const wardenRightCli = heroFlowCirclePoint(warden, rootRect, 340);
          const wardenRightPr = heroFlowCirclePoint(warden, rootRect, 20);
          connectors.push(...skillConnectors);
          connectors.push(heroFlowCurve(wardenRightCli, heroFlowPoint(cli, "left", rootRect)));
          connectors.push(heroFlowCurve(wardenRightPr, heroFlowPoint(pr, "left", rootRect)));
        }

        for (let i = 0; i < lines.length; i += 1) {
          const d = connectors[i] || "";
          if (lines[i]) lines[i].setAttribute("d", d);
          flow.querySelectorAll(`[data-trail='${i}']`).forEach((trail) => {
            trail.setAttribute("d", d);
          });
          if (maskLines[i]) {
            maskLines[i].setAttribute("d", d);
          }
        }
      };

      const ro = new ResizeObserver(update);
      ro.observe(flow);
      skills.forEach((el) => ro.observe(el));
      ro.observe(warden);
      ro.observe(cli);
      ro.observe(pr);

      window.addEventListener("resize", update);
      update();

      flow.__heroFlowCleanup = () => {
        ro.disconnect();
        window.removeEventListener("resize", update);
        if (motionEnabled) {
          window.removeEventListener("pointermove", onPointerMove);
          window.removeEventListener("blur", resetMascotTargets);
          document.removeEventListener("mouseleave", resetMascotTargets);
          document.removeEventListener("visibilitychange", onVisibilityChange);
        }
        if (rafId !== 0) {
          window.cancelAnimationFrame(rafId);
          rafId = 0;
        }
        trailHandlers.forEach(({ trail, onIteration }) => {
          trail.removeEventListener("animationiteration", onIteration);
        });
      };
    });
  }

  setupHeroFlows();
  document.addEventListener("astro:page-load", setupHeroFlows);
</script>

<style>
  .hero-flow {
    position: relative;
    width: min(1100px, calc(100vw - 2rem));
    margin: 0 auto 2.25rem;
  }

  .hero-flow-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.7;
    background-image: radial-gradient(circle at 0 0, #777 1.5px, #0000 0), radial-gradient(circle at 100% 100%, #777 1.5px, #0000 0);
    background-position: 0 0, 10px 10px;
    background-size: 20px 20px;
    -webkit-mask-image: radial-gradient(circle var(--hero-flow-mask-radius, 10rem) at 50% 50%, #000 0%, transparent 100%);
    mask-image: radial-gradient(circle var(--hero-flow-mask-radius, 10rem) at 50% 50%, #000 0%, transparent 100%);
  }

  .hero-flow-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .hero-flow-line {
    fill: none;
    stroke: rgba(255, 255, 255, 0.2);
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 4 6;
  }

  .hero-flow-mask-path {
    fill: none;
    stroke: #fff;
    stroke-width: 2.3;
    stroke-linecap: round;
    stroke-dasharray: 4 6;
  }

  .hero-flow-trail {
    fill: none;
    stroke: #22d3ee;
    stroke-width: 2.3;
    stroke-linecap: round;
    --trail-pattern: 14 286;
    stroke-dasharray: var(--trail-pattern);
    stroke-dashoffset: 0;
    animation: hero-flow-trail 15s steps(30, end) infinite;
    animation-delay: var(--trail-delay);
  }

  @keyframes hero-flow-trail {
    from {
      stroke-dasharray: var(--trail-pattern);
      stroke-dashoffset: 0;
    }
    to {
      stroke-dasharray: var(--trail-pattern);
      stroke-dashoffset: -300;
    }
  }

  .hero-flow-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    min-height: 27.5rem;
  }

  .hero-flow-column {
    min-width: 0;
  }

